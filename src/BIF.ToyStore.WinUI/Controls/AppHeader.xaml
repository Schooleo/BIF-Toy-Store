<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="BIF.ToyStore.WinUI.Controls.AppHeader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="18" VerticalAlignment="Center">
            <Image Source="ms-appx:///Assets/Icons/Bell.svg" Width="18" Height="18" Opacity="0.8" />
            <Image Source="ms-appx:///Assets/Icons/Help.svg" Width="18" Height="18" Opacity="0.8" />
            <Rectangle Width="1" Height="32" 
                       Fill="{StaticResource FluentPlayOutlineVariantBrush}"
                       Opacity="0.75" />
            <TextBlock x:Name="RoleText"
                       Text="ADMIN"
                       FontSize="16"
                       FontWeight="Bold"
                       CharacterSpacing="80"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
            <Border x:Name="RoleAvatar"
                    Width="32"
                    Height="32"
                    CornerRadius="16"
                    Background="{StaticResource FluentPlayPrimaryBrush}">
                <TextBlock x:Name="RoleInitialText"
                           Text="A"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontWeight="Bold" />
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
