    <Border Background="{StaticResource FluentPlaySurfaceContainerLowBrush}"
            BorderBrush="#1AC0C7D4"
            BorderThickness="0,0,1,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Padding="24,32,24,24">
                <Border Background="{StaticResource FluentPlayPrimaryBrush}"
                        CornerRadius="8"
                        Width="32"
                        Height="32">
                    <Image Source="ms-appx:///Assets/Icons/Robot.svg" Width="18" Height="18" />
                </Border>
                <StackPanel Spacing="1" VerticalAlignment="Center">
                    <TextBlock Text="Toy Workshop"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                    <TextBlock Text="CURATED EXCELLENCE"
                               FontSize="10"
                               CharacterSpacing="40"
                               Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"
                               Opacity="0.75" />
                </StackPanel>
            </StackPanel>

