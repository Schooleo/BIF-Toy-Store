<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="BIF.ToyStore.WinUI.Controls.ProductDetailsForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:BIF.ToyStore.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:BIF.ToyStore.Core.Models"
    RequestedTheme="Light"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:StringNullOrEmptyToVisibilityConverter x:Key="StringNullOrEmptyToVisibilityConverter" />
        <converters:InverseStringNullOrEmptyToVisibilityConverter x:Key="InverseStringNullOrEmptyToVisibilityConverter" />
        <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter" />
        <converters:DecimalToDoubleConverter x:Key="DecimalToDoubleConverter" />

        <Style x:Key="DetailsLabelStyle" TargetType="TextBlock">
            <Setter Property="CharacterSpacing" Value="100" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{ThemeResource FluentPlayOnSurfaceVariantBrush}" />
        </Style>

        <Style x:Key="DetailsTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource AppInputTextBoxStyle}">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="DetailsNumberBoxStyle" TargetType="NumberBox">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{ThemeResource FluentPlaySurfaceContainerLowBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource FluentPlayOutlineVariantBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{ThemeResource FluentPlayOnSurfaceBrush}" />
        </Style>
    </UserControl.Resources>

    <Border
        Width="430"
        MinWidth="430"
        VerticalAlignment="Stretch"
        HorizontalAlignment="Right"
        Background="{ThemeResource FluentPlaySurfaceBrush}"
        BorderBrush="{ThemeResource FluentPlayOutlineVariantBrush}"
        BorderThickness="1,0,0,0">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Padding="22,20"
                BorderBrush="{ThemeResource FluentPlayOutlineVariantBrush}"
                BorderThickness="0,0,0,1">
                <StackPanel Spacing="3">
                    <TextBlock
                        FontSize="30"
                        FontWeight="ExtraBold"
                        Foreground="{ThemeResource FluentPlayOnSurfaceBrush}"
                        Text="Edit Product" />
                    <TextBlock
                        FontSize="16"
                        Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}"
                        Text="Update product information before saving." />
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Padding="22,18,22,20" Spacing="14">
                    <InfoBar
                        IsClosable="False"
                        IsOpen="{x:Bind IsErrorOpen, Mode=OneWay}"
                        Message="{x:Bind EditErrorMessage, Mode=OneWay}"
                        Severity="Error" />

                    <InfoBar
                        IsClosable="False"
                        IsOpen="{x:Bind IsUploadErrorOpen, Mode=OneWay}"
                        Message="{x:Bind UploadErrorMessage, Mode=OneWay}"
                        Severity="Error" />

                    <Button Height="168"
                            HorizontalAlignment="Stretch"
                            Padding="0"
                            Click="UploadImageButton_Click"
                            Background="{ThemeResource FluentPlaySurfaceContainerHighBrush}"
                            BorderBrush="{ThemeResource FluentPlayOutlineVariantBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <Grid>
                            <Image Source="{x:Bind CurrentImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}}"
                                   Stretch="UniformToFill"
                                   Visibility="{x:Bind CurrentImageUrl, Mode=OneWay, Converter={StaticResource InverseStringNullOrEmptyToVisibilityConverter}}" />

                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="8"
                                        Visibility="{x:Bind CurrentImageUrl, Mode=OneWay, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}">
                                <FontIcon FontSize="28"
                                          Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}"
                                          Glyph="&#xE7C3;" />
                                <TextBlock FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}"
                                           Text="UPLOAD IMAGE" />
                            </StackPanel>

                            <ProgressRing Width="32"
                                          Height="32"
                                          IsActive="{x:Bind IsUploadingImage, Mode=OneWay}"
                                          Foreground="{ThemeResource FluentPlayPrimaryBrush}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Visibility="{x:Bind IsUploadingImage, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                    </Button>

                    <StackPanel Spacing="6">
                        <TextBlock Style="{StaticResource DetailsLabelStyle}" Text="NAME" />
                        <TextBox
                            Style="{StaticResource DetailsTextBoxStyle}"
                            Text="{x:Bind EditableProduct.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            TextChanged="FieldChanged_ClearError" />
                    </StackPanel>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Style="{StaticResource DetailsLabelStyle}" Text="RETAIL PRICE" />
                            <NumberBox
                                Minimum="0"
                                SpinButtonPlacementMode="Hidden"
                                Style="{StaticResource DetailsNumberBoxStyle}"
                                Value="{x:Bind EditableProduct.RetailPrice, Mode=TwoWay, Converter={StaticResource DecimalToDoubleConverter}}"
                                ValueChanged="FieldChanged_ClearError" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock Style="{StaticResource DetailsLabelStyle}" Text="IMPORT PRICE" />
                            <NumberBox
                                Minimum="0"
                                SpinButtonPlacementMode="Hidden"
                                Style="{StaticResource DetailsNumberBoxStyle}"
                                Value="{x:Bind EditableProduct.ImportPrice, Mode=TwoWay, Converter={StaticResource DecimalToDoubleConverter}}"
                                ValueChanged="FieldChanged_ClearError" />
                        </StackPanel>
                    </Grid>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Style="{StaticResource DetailsLabelStyle}" Text="CATEGORY" />
                            <Button x:Name="CategorySelectorButton"
                                MinHeight="40"
                                Padding="10,6"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                VerticalContentAlignment="Center"
                                Background="{ThemeResource FluentPlaySurfaceContainerLowBrush}"
                                BorderBrush="{ThemeResource FluentPlayOutlineVariantBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <PathIcon
                                        Width="14"
                                        Height="14"
                                        Data="M0 3H16V5H0V3ZM2 7H14V9H2V7ZM5 11H11V13H5V11Z"
                                        Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}" />
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="Normal"
                                        Foreground="{ThemeResource FluentPlayOnSurfaceBrush}"
                                        Text="{x:Bind SelectedCategoryDisplay, Mode=OneWay}" />
                                </StackPanel>
                                <Button.Flyout>
                                    <Flyout>
                                        <StackPanel MinWidth="180" Spacing="4">
                                            <TextBlock
                                                Margin="0,0,0,6"
                                                CharacterSpacing="100"
                                                FontSize="10"
                                                FontWeight="Bold"
                                                Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}"
                                                Text="CATEGORY" />
                                            <ListView
                                                Background="Transparent"
                                                BorderThickness="0"
                                                ItemsSource="{x:Bind Categories, Mode=OneWay}"
                                                SelectedValue="{x:Bind EditableProduct.CategoryId, Mode=OneWay}"
                                                SelectedValuePath="Id"
                                                SelectionChanged="CategoryList_SelectionChanged"
                                                SelectionMode="Single">
                                                <ListView.ItemContainerStyle>
                                                    <Style TargetType="ListViewItem">
                                                        <Setter Property="MinHeight" Value="32" />
                                                        <Setter Property="Padding" Value="8,4" />
                                                    </Style>
                                                </ListView.ItemContainerStyle>
                                                <ListView.ItemTemplate>
                                                    <DataTemplate x:DataType="models:Category">
                                                        <TextBlock Text="{x:Bind Name}" />
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock Style="{StaticResource DetailsLabelStyle}" Text="STOCK QUANTITY" />
                            <NumberBox
                                Minimum="0"
                                SpinButtonPlacementMode="Hidden"
                                Style="{StaticResource DetailsNumberBoxStyle}"
                                Value="{x:Bind EditableProduct.StockQuantity, Mode=TwoWay}"
                                ValueChanged="FieldChanged_ClearError" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <Border
                Grid.Row="2"
                Padding="22,14,22,20"
                BorderBrush="{ThemeResource FluentPlayOutlineVariantBrush}"
                BorderThickness="0,1,0,0">
                <StackPanel
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="14">
                    <Button
                        Height="42"
                        MinWidth="132"
                        Padding="22,0"
                        Command="{x:Bind CancelCommand, Mode=OneWay}"
                        Content="Cancel" />

                    <Button
                        Height="42"
                        MinWidth="132"
                        Padding="22,0"
                        Background="{ThemeResource FluentPlayPrimaryBrush}"
                        BorderBrush="{ThemeResource FluentPlayPrimaryBrush}"
                        Command="{x:Bind SaveCommand, Mode=OneWay}"
                        Content="Save"
                        FontWeight="Bold"
                        Foreground="{ThemeResource FluentPlayOnPrimaryBrush}">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource FluentPlayPrimaryHoverColor}" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource FluentPlayPrimaryPressedColor}" />
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource FluentPlayOnPrimaryColor}" />
                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource FluentPlayOnPrimaryColor}" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="{StaticResource FluentPlayPrimaryHoverColor}" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="{StaticResource FluentPlayPrimaryPressedColor}" />
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
