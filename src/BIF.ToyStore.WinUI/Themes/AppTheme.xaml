<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="FluentPlayPrimaryColor">#FF005FAA</Color>
    <Color x:Key="FluentPlayOnPrimaryColor">#FFFFFFFF</Color>
    <Color x:Key="FluentPlayPrimaryContainerColor">#FF0078D4</Color>
    <Color x:Key="FluentPlayOnPrimaryContainerColor">#FFFFFFFF</Color>
    <Color x:Key="FluentPlayPrimaryFixedColor">#FFD3E3FF</Color>
    <Color x:Key="FluentPlayPrimaryFixedDimColor">#FFA3C9FF</Color>
    <Color x:Key="FluentPlayOnPrimaryFixedColor">#FF001C39</Color>
    <Color x:Key="FluentPlayOnPrimaryFixedVariantColor">#FF004883</Color>

    <Color x:Key="FluentPlaySecondaryColor">#FF7C5800</Color>
    <Color x:Key="FluentPlayOnSecondaryColor">#FFFFFFFF</Color>
    <Color x:Key="FluentPlaySecondaryContainerColor">#FFFDB700</Color>
    <Color x:Key="FluentPlayOnSecondaryContainerColor">#FF6A4B00</Color>
    <Color x:Key="FluentPlaySecondaryFixedColor">#FFFFDEA7</Color>
    <Color x:Key="FluentPlaySecondaryFixedDimColor">#FFFFBB18</Color>
    <Color x:Key="FluentPlayOnSecondaryFixedColor">#FF271900</Color>
    <Color x:Key="FluentPlayOnSecondaryFixedVariantColor">#FF5E4200</Color>

    <Color x:Key="FluentPlayTertiaryColor">#FF974700</Color>
    <Color x:Key="FluentPlayOnTertiaryColor">#FFFFFFFF</Color>
    <Color x:Key="FluentPlayTertiaryContainerColor">#FFBC5B00</Color>
    <Color x:Key="FluentPlayOnTertiaryContainerColor">#FFFFFFFF</Color>
    <Color x:Key="FluentPlayTertiaryFixedColor">#FFFFDBC8</Color>
    <Color x:Key="FluentPlayTertiaryFixedDimColor">#FFFFB689</Color>
    <Color x:Key="FluentPlayOnTertiaryFixedColor">#FF311300</Color>
    <Color x:Key="FluentPlayOnTertiaryFixedVariantColor">#FF743500</Color>

    <Color x:Key="FluentPlayErrorColor">#FFBA1A1A</Color>
    <Color x:Key="FluentPlayOnErrorColor">#FFFFFFFF</Color>
    <Color x:Key="FluentPlayErrorContainerColor">#FFFFDAD6</Color>
    <Color x:Key="FluentPlayOnErrorContainerColor">#FF93000A</Color>

    <Color x:Key="FluentPlaySurfaceColor">#FFF9F9F9</Color>
    <Color x:Key="FluentPlaySurfaceDimColor">#FFDADADA</Color>
    <Color x:Key="FluentPlaySurfaceBrightColor">#FFF9F9F9</Color>
    <Color x:Key="FluentPlaySurfaceContainerLowestColor">#FFFFFFFF</Color>
    <Color x:Key="FluentPlaySurfaceContainerLowColor">#FFF3F3F3</Color>
    <Color x:Key="FluentPlaySurfaceContainerColor">#FFEEEEEE</Color>
    <Color x:Key="FluentPlaySurfaceContainerHighColor">#FFE8E8E8</Color>
    <Color x:Key="FluentPlaySurfaceContainerHighestColor">#FFE2E2E2</Color>
    <Color x:Key="FluentPlaySurfaceVariantColor">#FFE2E2E2</Color>
    <Color x:Key="FluentPlayInverseSurfaceColor">#FF2F3131</Color>
    <Color x:Key="FluentPlayInverseOnSurfaceColor">#FFF1F1F1</Color>

    <Color x:Key="FluentPlayOnSurfaceColor">#FF1A1C1C</Color>
    <Color x:Key="FluentPlayOnSurfaceVariantColor">#FF404752</Color>
    <Color x:Key="FluentPlayOutlineColor">#FF717783</Color>
    <Color x:Key="FluentPlayOutlineVariantColor">#FFC0C7D4</Color>

    <Color x:Key="FluentPlayOverlayColor">#1A005FAA</Color>
    <Color x:Key="FluentPlayGlassColor">#D9FFFFFF</Color>

    <SolidColorBrush x:Key="FluentPlayPrimaryBrush" Color="{StaticResource FluentPlayPrimaryColor}" />
    <SolidColorBrush x:Key="FluentPlayOnPrimaryBrush" Color="{StaticResource FluentPlayOnPrimaryColor}" />
    <SolidColorBrush x:Key="FluentPlaySurfaceBrush" Color="{StaticResource FluentPlaySurfaceColor}" />
    <SolidColorBrush x:Key="FluentPlaySurfaceContainerLowBrush" Color="{StaticResource FluentPlaySurfaceContainerLowColor}" />
    <SolidColorBrush x:Key="FluentPlaySurfaceContainerHighBrush" Color="{StaticResource FluentPlaySurfaceContainerHighColor}" />
    <SolidColorBrush x:Key="FluentPlayOnSurfaceBrush" Color="{StaticResource FluentPlayOnSurfaceColor}" />
    <SolidColorBrush x:Key="FluentPlayOnSurfaceVariantBrush" Color="{StaticResource FluentPlayOnSurfaceVariantColor}" />
    <SolidColorBrush x:Key="FluentPlayOutlineVariantBrush" Color="{StaticResource FluentPlayOutlineVariantColor}" />

    <SolidColorBrush x:Key="LoginPrimaryBrush" Color="{StaticResource FluentPlayPrimaryColor}" />
    <SolidColorBrush x:Key="LoginSurfaceBrush" Color="{StaticResource FluentPlaySurfaceColor}" />
    <SolidColorBrush x:Key="LoginCardBrush" Color="{StaticResource FluentPlaySurfaceContainerLowColor}" />
    <SolidColorBrush x:Key="LoginCardFooterBrush" Color="{StaticResource FluentPlaySurfaceContainerHighColor}" />
    <SolidColorBrush x:Key="LoginTextBrush" Color="{StaticResource FluentPlayOnSurfaceVariantColor}" />
    <SolidColorBrush x:Key="LoginDividerBrush" Color="{StaticResource FluentPlayOutlineVariantColor}" />
    <SolidColorBrush x:Key="LoginOverlayBrush" Color="{StaticResource FluentPlayOverlayColor}" />
    <SolidColorBrush x:Key="LoginGlassBrush" Color="{StaticResource FluentPlayGlassColor}" />

    <SolidColorBrush x:Key="TextControlBackground" Color="{StaticResource FluentPlaySurfaceContainerLowColor}" />
    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{StaticResource FluentPlaySurfaceContainerLowColor}" />
    <SolidColorBrush x:Key="TextControlBackgroundFocused">#FFFFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="TextControlBackgroundDisabled">#FFEDEDED</SolidColorBrush>

    <SolidColorBrush x:Key="TextControlForeground" Color="{StaticResource FluentPlayOnSurfaceVariantColor}" />
    <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="{StaticResource FluentPlayOnSurfaceVariantColor}" />
    <SolidColorBrush x:Key="TextControlForegroundFocused" Color="{StaticResource FluentPlayOnSurfaceVariantColor}" />
    <SolidColorBrush x:Key="TextControlForegroundDisabled">#88404752</SolidColorBrush>

    <SolidColorBrush x:Key="TextControlPlaceholderForeground">#A6404752</SolidColorBrush>
    <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver">#A6404752</SolidColorBrush>
    <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused">#A6404752</SolidColorBrush>

    <SolidColorBrush x:Key="TextControlBorderBrush" Color="{StaticResource FluentPlayOutlineVariantColor}" />
    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="{StaticResource FluentPlayOutlineVariantColor}" />
    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="{StaticResource FluentPlayPrimaryColor}" />
    <SolidColorBrush x:Key="TextControlBorderBrushDisabled">#66C0C7D4</SolidColorBrush>

    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{StaticResource FluentPlaySurfaceContainerLowColor}" />
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush">#FFF8F8F8</SolidColorBrush>
    <SolidColorBrush x:Key="ControlFillColorTertiaryBrush">#FFFFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="ControlStrongFillColorDefaultBrush" Color="{StaticResource FluentPlayOnSurfaceVariantColor}" />
    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{StaticResource FluentPlayOutlineVariantColor}" />
    <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush">#66C0C7D4</SolidColorBrush>

    <Style x:Key="AppInputTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource DefaultTextBoxStyle}">
        <Setter Property="Foreground" Value="{StaticResource LoginTextBrush}" />
        <Setter Property="PlaceholderForeground" Value="#A6404752" />
        <Setter Property="SelectionHighlightColor" Value="{StaticResource LoginPrimaryBrush}" />
        <Setter Property="Background" Value="{StaticResource LoginCardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource LoginDividerBrush}" />
    </Style>

    <Style x:Key="AppInputPasswordBoxStyle" TargetType="PasswordBox" BasedOn="{StaticResource DefaultPasswordBoxStyle}">
        <Setter Property="Foreground" Value="{StaticResource LoginTextBrush}" />
        <Setter Property="Background" Value="{StaticResource LoginCardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource LoginDividerBrush}" />
    </Style>

    <Style x:Key="AppInputComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource DefaultComboBoxStyle}">
        <Setter Property="Foreground" Value="{StaticResource LoginTextBrush}" />
        <Setter Property="Background" Value="{StaticResource LoginCardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource LoginDividerBrush}" />
    </Style>

    <Style x:Key="AppCaptionTextStyle" TargetType="TextBlock" BasedOn="{StaticResource DefaultTextBlockStyle}">
        <Setter Property="Foreground" Value="{StaticResource LoginTextBrush}" />
    </Style>

    <Style TargetType="TextBox" BasedOn="{StaticResource AppInputTextBoxStyle}" />
    <Style TargetType="PasswordBox" BasedOn="{StaticResource AppInputPasswordBoxStyle}" />
    <Style TargetType="ComboBox" BasedOn="{StaticResource AppInputComboBoxStyle}" />
</ResourceDictionary>
