    <Style TargetType="PasswordBox" BasedOn="{StaticResource AppInputPasswordBoxStyle}" />
    <Style TargetType="ComboBox" BasedOn="{StaticResource AppInputComboBoxStyle}" />
    <Style TargetType="CheckBox" BasedOn="{StaticResource DefaultCheckBoxStyle}">
