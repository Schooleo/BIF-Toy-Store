        <Setter Property="Foreground" Value="{StaticResource FluentPlayOnPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource FluentPlayPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

