        <Setter Property="SelectionHighlightColor" Value="{StaticResource LoginPrimaryBrush}" />
        <Setter Property="Background" Value="{StaticResource LoginCardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource LoginDividerBrush}" />
    </Style>

    <Style x:Key="AppInputPasswordBoxStyle" TargetType="PasswordBox" BasedOn="{StaticResource DefaultPasswordBoxStyle}">
        <Setter Property="Foreground" Value="{StaticResource LoginTextBrush}" />
        <Setter Property="Background" Value="{StaticResource LoginCardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource LoginDividerBrush}" />
    </Style>

