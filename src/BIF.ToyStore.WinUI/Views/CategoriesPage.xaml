<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="BIF.ToyStore.WinUI.Views.CategoriesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:converters="using:BIF.ToyStore.WinUI.Converters"
    xmlns:custom="using:BIF.ToyStore.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:BIF.ToyStore.WinUI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:BIF.ToyStore.Core.Models"
    x:Name="RootPage"
    Background="{ThemeResource FluentPlaySurfaceBrush}"
    RequestedTheme="Light"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <SolidColorBrush x:Key="CategoriesSurfaceCardBrush" Color="{StaticResource FluentPlaySurfaceContainerLowestColor}" />

        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource FluentPlaySurfaceContainerHighColor}" />
        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource FluentPlaySurfaceVariantColor}" />
        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource FluentPlayOnSurfaceColor}" />
        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource FluentPlayOnSurfaceColor}" />
    </Page.Resources>

    <Grid Background="{StaticResource FluentPlaySurfaceBrush}">
        <ScrollViewer
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Auto">
            <Grid
                MaxWidth="1280"
                Padding="32"
                HorizontalAlignment="Stretch"
                RowSpacing="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Title Area  -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="30"
                            FontWeight="ExtraBold"
                            Foreground="{ThemeResource FluentPlayOnSurfaceBrush}"
                            Text="Category Management" />
                        <TextBlock
                            FontSize="16"
                            Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}"
                            Text="{x:Bind ViewModel.TotalCountLabel, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="12">
                        <Button
                            Background="{ThemeResource FluentPlayPrimaryBrush}"
                            Click="AddCategory_Click"
                            Content="ADD NEW CATEGORY"
                            FontWeight="Bold"
                            Foreground="{ThemeResource FluentPlayOnPrimaryBrush}"
                            Visibility="{x:Bind ViewModel.CanCreateCategories, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource FluentPlayPrimaryHoverColor}" />
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource FluentPlayPrimaryPressedColor}" />
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource FluentPlayOnPrimaryColor}" />
                                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource FluentPlayOnPrimaryColor}" />
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="{StaticResource FluentPlayPrimaryHoverColor}" />
                                <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="{StaticResource FluentPlayPrimaryPressedColor}" />
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>

                <!--  Filters Area  -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel
                        Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="24">

                        <StackPanel VerticalAlignment="Top" Spacing="6">
                            <TextBlock
                                CharacterSpacing="120"
                                FontSize="11"
                                FontWeight="Bold"
                                Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}"
                                Text="SEARCH CATEGORIES" />
                            <TextBox
                                Width="240"
                                HorizontalAlignment="Left"
                                TextChanged="SearchBox_TextChanged"
                                PlaceholderText="Enter category name..."
                                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </StackPanel>

                    <Button
                        Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Background="#FFFDB700"
                        BorderThickness="0"
                        Command="{x:Bind ViewModel.ClearFilterCommand}"
                        Content="Reset Filters"
                        FontWeight="Bold"
                        Foreground="#FF6A4B00">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFFFC94A" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#FFFFB300" />
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#FF6A4B00" />
                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#FF6A4B00" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#FFFFC94A" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#FFFFB300" />
                        </Button.Resources>
                    </Button>
                </Grid>

                <!--  DataGrid  -->
                <controls:DataGrid
                    x:Name="CategoriesDataGrid"
                    Grid.Row="2"
                    AutoGenerateColumns="False"
                    Background="{ThemeResource FluentPlaySurfaceContainerLowestBrush}"
                    BorderBrush="{ThemeResource FluentPlaySurfaceContainerHighBrush}"
                    BorderThickness="1"
                    IsReadOnly="True"
                    IsTabStop="False"
                    CanUserReorderColumns="False"
                    CanUserResizeColumns="False"
                    CanUserSortColumns="False"
                    CornerRadius="12"
                    GridLinesVisibility="Horizontal"
                    HorizontalGridLinesBrush="{ThemeResource FluentPlaySurfaceContainerHighBrush}"
                    ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                    PointerPressed="CategoriesDataGrid_PointerPressed"
                    RowHeight="72"
                    SelectionChanged="CategoriesDataGrid_SelectionChanged"
                    SelectionMode="Single"
                    UseSystemFocusVisuals="False">

                    <controls:DataGrid.Resources>
                        <Style TargetType="controls:DataGridCell">
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="UseSystemFocusVisuals" Value="False" />
                            <Setter Property="FocusVisualPrimaryBrush" Value="Transparent" />
                            <Setter Property="FocusVisualSecondaryBrush" Value="Transparent" />
                            <Setter Property="FocusVisualPrimaryThickness" Value="0" />
                            <Setter Property="FocusVisualSecondaryThickness" Value="0" />
                            <Setter Property="IsTabStop" Value="False" />
                        </Style>
                    </controls:DataGrid.Resources>

                    <controls:DataGrid.Columns>
                        <!--  COLUMN: CATEGORY  -->
                        <controls:DataGridTemplateColumn Width="2*" Header="CATEGORY">
                            <controls:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="models:Category">
                                    <Grid Padding="16,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Width="40"
                                            Height="40"
                                            Margin="0,0,12,0"
                                            Background="{ThemeResource FluentPlaySurfaceContainerHighBrush}"
                                            CornerRadius="8">
                                            <FontIcon
                                                FontSize="18"
                                                Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}"
                                                Glyph="&#xE8EC;" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="14"
                                                FontWeight="SemiBold"
                                                Text="{x:Bind Name}" />
                                            <TextBlock FontSize="10" Opacity="0.7">
                                                <Run Text="CAT-" /><Run Text="{x:Bind Id}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </controls:DataGridTemplateColumn.CellTemplate>
                        </controls:DataGridTemplateColumn>

                        <!--  COLUMN: PRODUCTS COUNT  -->
                        <controls:DataGridTemplateColumn Width="*" Header="PRODUCTS">
                            <controls:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="models:Category">
                                    <StackPanel
                                        Padding="16,0"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                        <Ellipse
                                            Width="8"
                                            Height="8"
                                            Fill="{ThemeResource FluentPlayPrimaryBrush}" />
                                        <TextBlock FontWeight="Medium">
                                            <Run Text="{x:Bind ProductCount}" />
                                            <Run Text="items" />
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </controls:DataGridTemplateColumn.CellTemplate>
                        </controls:DataGridTemplateColumn>

                        <!--  COLUMN: ACTIONS  -->
                        <controls:DataGridTemplateColumn Width="120" Header="ACTIONS">
                            <controls:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="models:Category">
                                    <StackPanel
                                        Padding="0,0,16,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                        <Button
                                            Padding="4"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            Click="EditCategory_Click"
                                            Tag="{x:Bind}"
                                            ToolTipService.ToolTip="Edit Category">
                                            <FontIcon
                                                FontSize="14"
                                                Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}"
                                                Glyph="&#xE70F;" />
                                        </Button>
                                        <Button
                                            Padding="4"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            Click="DeleteCategory_Click"
                                            Tag="{x:Bind}"
                                            ToolTipService.ToolTip="Delete Category">
                                            <FontIcon
                                                FontSize="14"
                                                Foreground="{ThemeResource FluentPlayErrorColor}"
                                                Glyph="&#xE74D;" />
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </controls:DataGridTemplateColumn.CellTemplate>
                        </controls:DataGridTemplateColumn>
                    </controls:DataGrid.Columns>
                </controls:DataGrid>

                <!--  Pagination  -->
                <custom:PaginationControl
                    Grid.Row="3"
                    Margin="0,8,0,0"
                    FirstPageCommand="{x:Bind ViewModel.FirstPageCommand, Mode=OneWay}"
                    LastPageCommand="{x:Bind ViewModel.LastPageCommand, Mode=OneWay}"
                    NextPageCommand="{x:Bind ViewModel.NextPageCommand, Mode=OneWay}"
                    PreviousPageCommand="{x:Bind ViewModel.PreviousPageCommand, Mode=OneWay}"
                    TotalItems="{x:Bind ViewModel.TotalCount, Mode=OneWay}" />
            </Grid>
        </ScrollViewer>

        <!--  Add Category Dialog  -->
        <ContentDialog
            x:Name="AddCategoryDialog"
            Title="Add New Category"
            PrimaryButtonText="Create"
            CloseButtonText="Cancel"
            DefaultButton="Primary"
            PrimaryButtonClick="AddCategoryDialog_PrimaryButtonClick"
            RequestedTheme="Light">
            <ContentDialog.Resources>
                <SolidColorBrush x:Key="ContentDialogBackground" Color="{StaticResource FluentPlaySurfaceContainerLowestColor}" />
                <SolidColorBrush x:Key="ContentDialogForeground" Color="{StaticResource FluentPlayOnSurfaceVariantColor}" />
                <SolidColorBrush x:Key="ContentDialogTitleForeground" Color="{StaticResource FluentPlayOnSurfaceColor}" />
                <SolidColorBrush x:Key="ContentDialogBorderBrush" Color="{StaticResource FluentPlayOutlineVariantColor}" />
                <SolidColorBrush x:Key="AccentButtonBackground" Color="{StaticResource FluentPlayPrimaryColor}" />
                <SolidColorBrush x:Key="AccentButtonForeground" Color="{StaticResource FluentPlayOnPrimaryColor}" />
                <SolidColorBrush x:Key="AccentButtonBorderBrush" Color="{StaticResource FluentPlayPrimaryColor}" />
                <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver" Color="{StaticResource FluentPlayPrimaryHoverColor}" />
                <SolidColorBrush x:Key="AccentButtonBackgroundPressed" Color="{StaticResource FluentPlayPrimaryPressedColor}" />
                <SolidColorBrush x:Key="AccentButtonForegroundPointerOver" Color="{StaticResource FluentPlayOnPrimaryColor}" />
                <SolidColorBrush x:Key="AccentButtonForegroundPressed" Color="{StaticResource FluentPlayOnPrimaryColor}" />
                <SolidColorBrush x:Key="AccentButtonBorderBrushPointerOver" Color="{StaticResource FluentPlayPrimaryHoverColor}" />
                <SolidColorBrush x:Key="AccentButtonBorderBrushPressed" Color="{StaticResource FluentPlayPrimaryPressedColor}" />
                <SolidColorBrush x:Key="ButtonBackground" Color="{StaticResource FluentPlaySurfaceContainerLowestColor}" />
                <SolidColorBrush x:Key="ButtonForeground" Color="{StaticResource FluentPlayOnSurfaceVariantColor}" />
                <SolidColorBrush x:Key="ButtonBorderBrush" Color="{StaticResource FluentPlayOutlineVariantColor}" />
            </ContentDialog.Resources>
            <StackPanel Spacing="12" MinWidth="320">
                <StackPanel Spacing="4">
                    <TextBlock Text="CATEGORY NAME" FontSize="10" FontWeight="Bold" Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}" />
                    <TextBox
                        x:Name="AddCategoryNameTextBox"
                        PlaceholderText="e.g. Action Figures"
                        HorizontalAlignment="Stretch" />
                </StackPanel>
                <TextBlock
                    x:Name="AddCategoryError"
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    FontSize="11"
                    Visibility="Collapsed"
                    Text="Category name is required." />
            </StackPanel>
        </ContentDialog>

        <!--  Edit Category Dialog  -->
        <ContentDialog
            x:Name="EditCategoryDialog"
            Title="Edit Category"
            PrimaryButtonText="Update"
            CloseButtonText="Cancel"
            DefaultButton="Primary"
            PrimaryButtonClick="EditCategoryDialog_PrimaryButtonClick"
            RequestedTheme="Light">
            <ContentDialog.Resources>
                <SolidColorBrush x:Key="ContentDialogBackground" Color="{StaticResource FluentPlaySurfaceContainerLowestColor}" />
                <SolidColorBrush x:Key="ContentDialogForeground" Color="{StaticResource FluentPlayOnSurfaceVariantColor}" />
                <SolidColorBrush x:Key="ContentDialogTitleForeground" Color="{StaticResource FluentPlayOnSurfaceColor}" />
                <SolidColorBrush x:Key="ContentDialogBorderBrush" Color="{StaticResource FluentPlayOutlineVariantColor}" />
                <SolidColorBrush x:Key="AccentButtonBackground" Color="{StaticResource FluentPlayPrimaryColor}" />
                <SolidColorBrush x:Key="AccentButtonForeground" Color="{StaticResource FluentPlayOnPrimaryColor}" />
                <SolidColorBrush x:Key="AccentButtonBorderBrush" Color="{StaticResource FluentPlayPrimaryColor}" />
                <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver" Color="{StaticResource FluentPlayPrimaryHoverColor}" />
                <SolidColorBrush x:Key="AccentButtonBackgroundPressed" Color="{StaticResource FluentPlayPrimaryPressedColor}" />
                <SolidColorBrush x:Key="AccentButtonForegroundPointerOver" Color="{StaticResource FluentPlayOnPrimaryColor}" />
                <SolidColorBrush x:Key="AccentButtonForegroundPressed" Color="{StaticResource FluentPlayOnPrimaryColor}" />
                <SolidColorBrush x:Key="AccentButtonBorderBrushPointerOver" Color="{StaticResource FluentPlayPrimaryHoverColor}" />
                <SolidColorBrush x:Key="AccentButtonBorderBrushPressed" Color="{StaticResource FluentPlayPrimaryPressedColor}" />
                <SolidColorBrush x:Key="ButtonBackground" Color="{StaticResource FluentPlaySurfaceContainerLowestColor}" />
                <SolidColorBrush x:Key="ButtonForeground" Color="{StaticResource FluentPlayOnSurfaceVariantColor}" />
                <SolidColorBrush x:Key="ButtonBorderBrush" Color="{StaticResource FluentPlayOutlineVariantColor}" />
            </ContentDialog.Resources>
            <StackPanel Spacing="12" MinWidth="320">
                <StackPanel Spacing="4">
                    <TextBlock Text="CATEGORY NAME" FontSize="10" FontWeight="Bold" Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}" />
                    <TextBox
                        x:Name="EditCategoryNameTextBox"
                        PlaceholderText="e.g. Action Figures"
                        HorizontalAlignment="Stretch" />
                </StackPanel>
                <TextBlock
                    x:Name="EditCategoryError"
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    FontSize="11"
                    Visibility="Collapsed"
                    Text="Category name is required." />
            </StackPanel>
        </ContentDialog>
    </Grid>
</Page>
