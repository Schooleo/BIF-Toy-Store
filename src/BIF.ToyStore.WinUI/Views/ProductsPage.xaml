<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="BIF.ToyStore.WinUI.Views.ProductsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:controls1="using:CommunityToolkit.WinUI.Controls"
    xmlns:custom="using:BIF.ToyStore.WinUI.Controls"
    xmlns:converters="using:BIF.ToyStore.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:BIF.ToyStore.WinUI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:BIF.ToyStore.Core.Models"
    x:Name="RootPage"
    RequestedTheme="Light"
    Background="{ThemeResource FluentPlaySurfaceBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:StockFormatConverter x:Key="StockFormatConverter" />
        <SolidColorBrush x:Key="ProductsSurfaceCardBrush" Color="{StaticResource FluentPlaySurfaceContainerLowestColor}" />
        <SolidColorBrush x:Key="ProductsDangerBrush" Color="{StaticResource FluentPlayErrorColor}" />
        <SolidColorBrush x:Key="SliderTrackValueFill" Color="{StaticResource FluentPlayPrimaryColor}" />
        <SolidColorBrush x:Key="SliderTrackFill" Color="{StaticResource FluentPlayOutlineVariantColor}" />
        <SolidColorBrush x:Key="SliderThumbBackground" Color="{StaticResource FluentPlayPrimaryColor}" />
        <SolidColorBrush x:Key="DataGridRowSelectedBackgroundBrush" Color="{StaticResource FluentPlayPrimaryFixedColor}" />
        <SolidColorBrush x:Key="DataGridRowSelectedForegroundBrush" Color="{StaticResource FluentPlayOnSurfaceColor}" />
    </Page.Resources>

    <Grid Background="{StaticResource FluentPlaySurfaceBrush}">
        <ScrollViewer
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Auto"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled">
            <Grid
                Padding="32"
                RowSpacing="24"
                MaxWidth="1280"
                HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

            <!--  Title Area  -->
                <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                    <TextBlock
                        FontSize="30"
                        FontWeight="ExtraBold"
                        Foreground="{ThemeResource FluentPlayOnSurfaceBrush}"
                        Text="Inventory Management" />
                        <TextBlock
                            FontSize="16"
                            Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}"
                            Text="{x:Bind ViewModel.TotalCountLabel, Mode=OneWay}" />
                    <TextBlock
                        Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                        Text="{x:Bind ViewModel.ImportSuccessMessage, Mode=OneWay}"
                        TextWrapping="Wrap"
                        Visibility="{x:Bind ViewModel.HasImportSuccessMessage, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock
                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                        Text="{x:Bind ViewModel.ImportErrorMessage, Mode=OneWay}"
                        TextWrapping="Wrap"
                        Visibility="{x:Bind ViewModel.HasImportErrorMessage, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>

                    <StackPanel
                        Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="12"
                        VerticalAlignment="Center">
                    <Button
                        Background="{ThemeResource ProductsSurfaceCardBrush}"
                        BorderBrush="{ThemeResource FluentPlayOutlineVariantBrush}"
                        Command="{x:Bind ViewModel.ImportExcelCommand}"
                        Content="Import Excel"
                        Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}" />
                    <Button
                        Background="{ThemeResource FluentPlayPrimaryBrush}"
                        Click="AddProduct_Click"
                        Content="ADD NEW PRODUCT"
                        FontWeight="Bold"
                        Foreground="{ThemeResource FluentPlayOnPrimaryBrush}" />
                </StackPanel>
            </Grid>

            <!--  Filters Area  -->
                <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                    <StackPanel
                        Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="24">

                    <StackPanel VerticalAlignment="Top" Spacing="6">
                            <TextBlock
                                FontSize="11"
                                FontWeight="Bold"
                                CharacterSpacing="120"
                                Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}"
                                Text="SEARCH INVENTORY" />
                        <TextBox
                            Width="240"
                            HorizontalAlignment="Left"
                            KeyDown="SearchBox_KeyDown"
                            PlaceholderText="Enter product name..."
                            Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel VerticalAlignment="Top" Spacing="6">
                            <TextBlock
                                FontSize="11"
                                FontWeight="Bold"
                                CharacterSpacing="120"
                                Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}"
                                Text="CATEGORY" />
                        <ComboBox
                            Width="160"
                            DisplayMemberPath="Name"
                            ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                            MaxDropDownHeight="300"
                            PlaceholderText="All Categories"
                            SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                            SelectionChanged="Filter_Changed" />
                    </StackPanel>

                    <StackPanel VerticalAlignment="Top" Spacing="6">
                            <TextBlock
                                FontSize="11"
                                FontWeight="Bold"
                                CharacterSpacing="120"
                                Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}"
                                Text="SORT BY" />
                        <ComboBox
                            Width="160"
                            DisplayMemberPath="Name"
                            ItemsSource="{x:Bind ViewModel.SortOptions}"
                            MaxDropDownHeight="300"
                            PlaceholderText="Newest"
                            SelectedItem="{x:Bind ViewModel.SelectedSort, Mode=TwoWay}"
                            SelectionChanged="Filter_Changed" />
                    </StackPanel>

                    <StackPanel VerticalAlignment="Top" Spacing="6">
                            <TextBlock
                                FontSize="11"
                                FontWeight="Bold"
                                CharacterSpacing="120"
                                Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}"
                                Text="PRICE RANGE" />
                        <controls1:RangeSelector
                            Width="200"
                            Margin="8,4,8,0"
                            VerticalAlignment="Center"
                            Maximum="1000"
                            Minimum="0"
                            PointerReleased="Filter_Changed"
                            RangeEnd="{x:Bind ViewModel.MaxPrice, Mode=TwoWay}"
                            RangeStart="{x:Bind ViewModel.MinPrice, Mode=TwoWay}"
                            StepFrequency="10" />
                    </StackPanel>
                </StackPanel>

                    <Button
                        Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Background="Transparent"
                        Command="{x:Bind ViewModel.ClearFilterCommand}"
                        Content="Reset Filters"
                        Foreground="{ThemeResource FluentPlayPrimaryBrush}" />
                </Grid>

            <!--  DataGrid  -->
            <controls:DataGrid
                Grid.Row="2"
                AutoGenerateColumns="False"
                Background="{ThemeResource ProductsSurfaceCardBrush}"
                BorderBrush="{ThemeResource FluentPlaySurfaceContainerHighBrush}"
                BorderThickness="1"
                CanUserSortColumns="True"
                CornerRadius="12"
                GridLinesVisibility="Horizontal"
                HorizontalGridLinesBrush="{ThemeResource FluentPlaySurfaceContainerHighBrush}"
                ItemsSource="{x:Bind ViewModel.Products, Mode=OneWay}"
                RowHeight="72">
                <controls:DataGrid.Columns>
                    <controls:DataGridTemplateColumn Width="2*" Header="PRODUCT">
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="models:Product">
                                <Grid Padding="16,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Width="40"
                                        Height="40"
                                        Margin="0,0,12,0"
                                        Background="{ThemeResource FluentPlaySurfaceContainerHighBrush}"
                                        CornerRadius="8" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{ThemeResource FluentPlayOnSurfaceBrush}"
                                            Text="{x:Bind Name}" />
                                        <TextBlock FontSize="10" Foreground="{ThemeResource FluentPlayOutlineVariantBrush}">
                                            <Run Text="SKU: TOY-" /><Run Text="{x:Bind Id}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>

                    <controls:DataGridTemplateColumn Width="*" Header="CATEGORY">
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="models:Product">
                                <Border
                                    Margin="16,0"
                                    Padding="8,4"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="{ThemeResource FluentPlaySurfaceContainerHighBrush}"
                                    CornerRadius="4">
                                    <TextBlock
                                        FontSize="10"
                                        FontWeight="Bold"
                                        Foreground="{ThemeResource FluentPlayOnSurfaceBrush}"
                                        Text="{x:Bind Category.Name}" />
                                </Border>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>

                    <controls:DataGridTextColumn
                        Width="*"
                        Binding="{Binding RetailPrice}"
                        Header="RETAIL" />

                    <controls:DataGridTemplateColumn Width="*" Header="STOCK">
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="models:Product">
                                <StackPanel
                                    Padding="16,0"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="8">
                                    <Ellipse
                                        Width="8"
                                        Height="8"
                                        Fill="{ThemeResource FluentPlayPrimaryBrush}" />
                                    <TextBlock FontWeight="Medium" Text="{x:Bind StockQuantity, Converter={StaticResource StockFormatConverter}}" />
                                </StackPanel>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>

                    <controls:DataGridTemplateColumn Width="100" Header="ACTIONS">
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="models:Product">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="0,0,16,0">
                                    <Button Background="Transparent" BorderBrush="Transparent" Padding="4" Tag="{x:Bind}" Click="EditProduct_Click"
                                            ToolTipService.ToolTip="Edit Product">
                                        <FontIcon Glyph="&#xE70F;" FontSize="14" Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}" />
                                    </Button>
                                    <Button Background="Transparent" BorderBrush="Transparent" Padding="4" Tag="{x:Bind}" Click="DeleteProduct_Click"
                                            ToolTipService.ToolTip="Delete Product">
                                        <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{ThemeResource ProductsDangerBrush}" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>
                </controls:DataGrid.Columns>
            </controls:DataGrid>

            <!--  Pagination  -->
            <custom:PaginationControl
                Grid.Row="3"
                Margin="0,8,0,0"
                FirstPageCommand="{x:Bind ViewModel.FirstPageCommand, Mode=OneWay}"
                LastPageCommand="{x:Bind ViewModel.LastPageCommand, Mode=OneWay}"
                NextPageCommand="{x:Bind ViewModel.NextPageCommand, Mode=OneWay}"
                PreviousPageCommand="{x:Bind ViewModel.PreviousPageCommand, Mode=OneWay}"
                TotalItems="{x:Bind ViewModel.TotalCount, Mode=OneWay}" />
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
