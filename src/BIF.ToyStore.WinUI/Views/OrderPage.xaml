<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BIF.ToyStore.WinUI.Views.OrderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls2="using:BIF.ToyStore.WinUI.Controls"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:BIF.ToyStore.WinUI.Views"
    xmlns:vm="using:BIF.ToyStore.ViewModels.Pages"
    xmlns:converters="using:BIF.ToyStore.WinUI.Converters"
    x:Name="RootPage"
    Background="{ThemeResource FluentPlaySurfaceBrush}"
    RequestedTheme="Light"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:OrderStatusTagBrushConverter x:Key="OrderStatusTagBrushConverter"/>
        <SolidColorBrush x:Key="ProductsSurfaceCardBrush"
                         Color="{StaticResource FluentPlaySurfaceContainerLowestColor}"/>
        <SolidColorBrush x:Key="DataGridRowSelectedBackgroundBrush"
                         Color="Transparent"/>
        <SolidColorBrush x:Key="DataGridRowSelectedForegroundBrush"
                         Color="{StaticResource FluentPlayOnSurfaceColor}"/>

        <SolidColorBrush x:Key="ButtonBackgroundPointerOver"
                         Color="{StaticResource FluentPlaySurfaceContainerHighColor}"/>
        <SolidColorBrush x:Key="ButtonBackgroundPressed"
                         Color="{StaticResource FluentPlaySurfaceVariantColor}"/>
        <SolidColorBrush x:Key="ButtonForegroundPointerOver"
                         Color="{StaticResource FluentPlayOnSurfaceColor}"/>
        <SolidColorBrush x:Key="ButtonForegroundPressed"
                         Color="{StaticResource FluentPlayOnSurfaceColor}"/>

        <Style x:Key="OrderCalendarDatePickerStyle"
               TargetType="CalendarDatePicker">
            <Setter Property="Foreground"
                    Value="{ThemeResource CalendarDatePickerTextForeground}"/>
            <Setter Property="Background"
                    Value="{ThemeResource CalendarDatePickerBackground}"/>
            <Setter Property="BorderBrush"
                    Value="{ThemeResource CalendarDatePickerBorderBrush}"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="CornerRadius"
                    Value="8"/>
            <Setter Property="Padding"
                    Value="12,8"/>
            <Setter Property="HorizontalAlignment"
                    Value="Stretch"/>
        </Style>

        <Style x:Key="FilterFlyoutPresenterStyle"
               TargetType="FlyoutPresenter">
            <Setter Property="Background"
                    Value="{ThemeResource FluentPlaySurfaceContainerLowestBrush}"/>
            <Setter Property="BorderBrush"
                    Value="{ThemeResource FluentPlayOutlineVariantBrush}"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="CornerRadius"
                    Value="8"/>
            <Setter Property="Padding"
                    Value="8"/>
        </Style>
    </Page.Resources>

    <!-- Root: The main content plus the dismissible overlay -->
    <Grid Background="{StaticResource FluentPlaySurfaceBrush}">
        <ScrollViewer
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Auto">
            <Grid
                MaxWidth="1280"
                Padding="32"
                HorizontalAlignment="Stretch"
                RowSpacing="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header Row -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Spacing="4">
                        <TextBlock Text="Order Management"
                                   FontSize="30"
                                   FontWeight="ExtraBold"
                                   Foreground="{ThemeResource FluentPlayOnSurfaceBrush}"/>
                        <TextBlock Text="Review and process recent workshop transactions"
                                   FontSize="16"
                                   Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="12"
                                VerticalAlignment="Bottom">
                        <Button x:Name="ExportButton"
                                Click="ExportButton_Click"
                                VerticalAlignment="Center"
                                Background="{ThemeResource ProductsSurfaceCardBrush}"
                                BorderBrush="{ThemeResource FluentPlayOutlineVariantBrush}"
                                Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <SymbolIcon Symbol="Save"
                                            Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}"/>
                                <TextBlock Text="Export Report"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Date Filter Row -->
                <Grid Grid.Row="1"
                      ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Visibility="{x:Bind ViewModel.IsEmployeeFilterVisible, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                        <TextBlock Text="EMPLOYEE"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   CharacterSpacing="120"
                                   Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"
                                   Margin="0,0,0,4"/>
                        <Button Width="220"
                                Height="40"
                                Padding="12,0"
                                HorizontalContentAlignment="Stretch"
                                Background="White"
                                BorderBrush="{ThemeResource FluentPlayOutlineVariantBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <FontIcon Glyph="&#xE13D;"
                                          VerticalAlignment="Center"
                                          Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.SelectedEmployeeDisplay, Mode=OneWay}"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource FluentPlayOnSurfaceBrush}"/>
                            </StackPanel>
                            <Button.Flyout>
                                <Flyout Placement="BottomEdgeAlignedLeft"
                                        FlyoutPresenterStyle="{StaticResource FilterFlyoutPresenterStyle}">
                                    <StackPanel Spacing="4"
                                                MinWidth="220">
                                        <TextBlock Text="FILTER BY EMPLOYEE"
                                                   Margin="0,0,0,6"
                                                   CharacterSpacing="100"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}"/>
                                        <ListView Width="220"
                                                  MaxHeight="240"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  ItemsSource="{x:Bind ViewModel.Employees, Mode=OneWay}"
                                                  SelectedItem="{x:Bind ViewModel.SelectedEmployee, Mode=TwoWay}"
                                                  SelectionChanged="Filter_Changed"
                                                  SelectionMode="Single">
                                            <ListView.ItemContainerStyle>
                                                <Style TargetType="ListViewItem">
                                                    <Setter Property="MinHeight"
                                                            Value="32"/>
                                                    <Setter Property="Padding"
                                                            Value="8,4"/>
                                                </Style>
                                            </ListView.ItemContainerStyle>
                                            <ListView.ItemTemplate>
                                                <DataTemplate x:DataType="vm:EmployeeListItem">
                                                    <TextBlock Text="{x:Bind Username}"/>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="FROM DATE"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   CharacterSpacing="120"
                                   Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"
                                   Margin="0,0,0,4"/>
                        <CalendarDatePicker x:Name="FromDatePicker"
                                            Width="200"
                                Height="40"
                                            Style="{StaticResource OrderCalendarDatePickerStyle}"
                                            DateChanged="Filter_Changed"
                                            Date="{x:Bind ViewModel.FromDate, Mode=TwoWay}"
                                            PlaceholderText="Select a starting date"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="TO DATE"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   CharacterSpacing="120"
                                   Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"
                                   Margin="0,0,0,4"/>
                        <CalendarDatePicker x:Name="ToDatePicker"
                                            Width="200"
                                Height="40"
                                            Style="{StaticResource OrderCalendarDatePickerStyle}"
                                            DateChanged="Filter_Changed"
                                            Date="{x:Bind ViewModel.ToDate, Mode=TwoWay}"
                                            PlaceholderText="Select an ending date"/>
                    </StackPanel>

                    <Button Grid.Column="3"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            Command="{x:Bind ViewModel.ClearFilterCommand}"
                            Content="Reset Filters"
                            Foreground="{ThemeResource FluentPlayPrimaryBrush}"/>
                </Grid>

                <!-- Order List -->
                <Grid Grid.Row="2">
                    <controls:DataGrid
                        x:Name="OrdersDataGrid"
                        AutoGenerateColumns="False"
                        Background="{ThemeResource FluentPlaySurfaceContainerLowestBrush}"
                        BorderBrush="{ThemeResource FluentPlaySurfaceContainerHighBrush}"
                        BorderThickness="1"
                        IsReadOnly="True"
                        IsTabStop="False"
                        CanUserReorderColumns="False"
                        CanUserResizeColumns="False"
                        CanUserSortColumns="False"
                        CornerRadius="12"
                        GridLinesVisibility="Horizontal"
                        HorizontalGridLinesBrush="{ThemeResource FluentPlaySurfaceContainerHighBrush}"
                        ItemsSource="{x:Bind ViewModel.Orders, Mode=OneWay}"
                        RowHeight="72"
                        SelectionMode="Single"
                        SelectionChanged="OrdersDataGrid_SelectionChanged"
                        Tapped="OrdersDataGrid_Tapped"
                        UseSystemFocusVisuals="False">

                        <controls:DataGrid.Resources>
                            <Style TargetType="controls:DataGridCell">
                                <Setter Property="BorderBrush"
                                        Value="Transparent"/>
                                <Setter Property="BorderThickness"
                                        Value="0"/>
                                <Setter Property="UseSystemFocusVisuals"
                                        Value="False"/>
                                <Setter Property="FocusVisualPrimaryBrush"
                                        Value="Transparent"/>
                                <Setter Property="FocusVisualSecondaryBrush"
                                        Value="Transparent"/>
                                <Setter Property="FocusVisualPrimaryThickness"
                                        Value="0"/>
                                <Setter Property="FocusVisualSecondaryThickness"
                                        Value="0"/>
                                <Setter Property="IsTabStop"
                                        Value="False"/>
                            </Style>
                        </controls:DataGrid.Resources>

                        <controls:DataGrid.Columns>
                            <controls:DataGridTemplateColumn Width="2*"
                                                             Header="ORDER">
                                <controls:DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate x:DataType="vm:OrderItemViewModel">
                                        <StackPanel Padding="16,8"
                                                    Spacing="2"
                                                    VerticalAlignment="Center">
                                            <HyperlinkButton Content="{x:Bind IdDisplay}"
                                                             Tag="{x:Bind}"
                                                             Click="ViewOrder_Click"
                                                             Padding="0"
                                                             FontSize="14"
                                                             FontWeight="SemiBold"
                                                             Foreground="{StaticResource FluentPlayPrimaryBrush}"/>
                                            <TextBlock Text="{x:Bind DateDisplay}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </controls:DataGridTemplateColumn.CellTemplate>
                            </controls:DataGridTemplateColumn>

                            <controls:DataGridTextColumn
                                Width="*"
                                Binding="{Binding EmployeeDisplay}"
                                Header="EMPLOYEE"/>

                            <controls:DataGridTextColumn
                                Width="*"
                                Binding="{Binding TotalDisplay}"
                                Header="TOTAL"/>

                            <controls:DataGridTemplateColumn Width="*"
                                                             Header="STATUS">
                                <controls:DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate x:DataType="vm:OrderItemViewModel">
                                        <Border Margin="16,0"
                                                Padding="8,4"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Background="{x:Bind Status, Mode=OneWay, Converter={StaticResource OrderStatusTagBrushConverter}, ConverterParameter=Background}"
                                                CornerRadius="16">
                                            <TextBlock Text="{x:Bind Status, Mode=OneWay}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{x:Bind Status, Mode=OneWay, Converter={StaticResource OrderStatusTagBrushConverter}, ConverterParameter=Foreground}"/>
                                        </Border>
                                    </DataTemplate>
                                </controls:DataGridTemplateColumn.CellTemplate>
                            </controls:DataGridTemplateColumn>

                            <controls:DataGridTemplateColumn Width="120"
                                                             Header="ACTIONS">
                                <controls:DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate x:DataType="vm:OrderItemViewModel">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Padding="0,0,16,0">
                                            <Button x:Name="ViewOrderButton"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    Padding="4"
                                                    Tag="{x:Bind}"
                                                    Click="ViewOrder_Click"
                                                    ToolTipService.ToolTip="View Details">
                                                <FontIcon Glyph="&#xE70F;"
                                                          FontSize="14"
                                                          Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                            </Button>
                                            <Button x:Name="DeleteOrderButton"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    Padding="4"
                                                    Tag="{x:Bind}"
                                                    Click="DeleteOrder_Click"
                                                    ToolTipService.ToolTip="Delete Order">
                                                <FontIcon Glyph="&#xE74D;"
                                                          FontSize="14"
                                                          Foreground="{StaticResource FluentPlayErrorColor}"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </controls:DataGridTemplateColumn.CellTemplate>
                            </controls:DataGridTemplateColumn>
                        </controls:DataGrid.Columns>
                    </controls:DataGrid>

                    <!-- Error Message -->
                    <InfoBar x:Name="ErrorBar"
                             IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                             Severity="Error"
                             Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                             IsClosable="True"
                             Margin="0,8,0,0"
                             VerticalAlignment="Bottom"/>
                </Grid>

                <!-- Pagination Row -->
                <controls2:PaginationControl Grid.Row="3"
                                             Margin="0,8,0,0"
                                             HorizontalAlignment="Center"
                                             FirstPageCommand="{x:Bind ViewModel.FirstPageCommand}"
                                             PreviousPageCommand="{x:Bind ViewModel.PreviousPageCommand}"
                                             NextPageCommand="{x:Bind ViewModel.NextPageCommand}"
                                             LastPageCommand="{x:Bind ViewModel.LastPageCommand}"
                                             TotalItems="{x:Bind ViewModel.TotalCount, Mode=OneWay}"/>

                <controls2:AppFooter Grid.Row="4"
                                     Margin="0,8,0,0"/>
            </Grid>
        </ScrollViewer>

        <!-- ─── Overlay dim when panel is open ─────────────────────────── -->
        <Border x:Name="DimOverlay"
                Background="#60000000"
                Visibility="{x:Bind ViewModel.IsDetailsPanelOpen, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
            <Border.Transitions>
                <TransitionCollection>
                    <EntranceThemeTransition/>
                </TransitionCollection>
            </Border.Transitions>
            <Grid/>
        </Border>

        <!-- ─── Order Details Sidebar ───────────────────────────────────── -->
        <Border x:Name="DetailsSidebar"
                Width="420"
                HorizontalAlignment="Right"
                Background="{StaticResource FluentPlaySurfaceContainerLowBrush}"
                BorderBrush="#1AC0C7D4"
                BorderThickness="1,0,0,0"
                Visibility="{x:Bind ViewModel.IsDetailsPanelOpen, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
            <Border.Transitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromHorizontalOffset="200"/>
                </TransitionCollection>
            </Border.Transitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Sidebar Header -->
                <Grid Grid.Row="0"
                      Padding="24,20"
                      BorderBrush="#1AC0C7D4"
                      BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Order Details"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                        <TextBlock Text="Purchased products and order info"
                                   FontSize="13"
                                   Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Command="{x:Bind ViewModel.CloseDetailsPanelCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Width="32"
                            Height="32"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Padding="0">
                        <SymbolIcon Symbol="Cancel"/>
                    </Button>
                </Grid>

                <!-- Scrollable Body -->
                <ScrollViewer Grid.Row="1"
                              Padding="24,20"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16"
                                DataContext="{x:Bind ViewModel.SelectedOrder, Mode=OneWay}">

                        <!-- Order Info Card -->
                        <Border Background="{StaticResource FluentPlaySurfaceBrush}"
                                CornerRadius="12"
                                Padding="16"
                                BorderBrush="#1AC0C7D4"
                                BorderThickness="1">
                            <Grid ColumnSpacing="12"
                                  RowSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Column="0"
                                            Grid.Row="0">
                                    <TextBlock Text="ORDER ID"
                                               FontSize="10"
                                               CharacterSpacing="40"
                                               Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.SelectedOrder.IdDisplay, Mode=OneWay}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource FluentPlayPrimaryBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Grid.Row="0">
                                    <TextBlock Text="STATUS"
                                               FontSize="10"
                                               CharacterSpacing="40"
                                               Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                    <Border CornerRadius="20"
                                            Padding="10,4"
                                            Margin="0,4,0,0"
                                            HorizontalAlignment="Left"
                                            Background="{x:Bind ViewModel.SelectedOrder.Status, Mode=OneWay, Converter={StaticResource OrderStatusTagBrushConverter}, ConverterParameter=Background}">
                                        <TextBlock Text="{x:Bind ViewModel.SelectedOrder.Status, Mode=OneWay}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{x:Bind ViewModel.SelectedOrder.Status, Mode=OneWay, Converter={StaticResource OrderStatusTagBrushConverter}, ConverterParameter=Foreground}"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="0"
                                            Grid.Row="1">
                                    <TextBlock Text="EMPLOYEE"
                                               FontSize="10"
                                               CharacterSpacing="40"
                                               Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.SelectedOrder.EmployeeDisplay, Mode=OneWay}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource FluentPlayOnSurfaceBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Grid.Row="1">
                                    <TextBlock Text="DATE"
                                               FontSize="10"
                                               CharacterSpacing="40"
                                               Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.SelectedOrder.DateDisplay, Mode=OneWay}"
                                               FontSize="14"
                                               Foreground="{StaticResource FluentPlayOnSurfaceBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Total Row -->
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Total"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind ViewModel.SelectedOrder.TotalDisplay, Mode=OneWay}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource FluentPlayPrimaryBrush}"/>
                        </Grid>

                        <!-- Update Status -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="UPDATE STATUS"
                                       FontSize="13"
                                       CharacterSpacing="40"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Content="New"
                                        Tag="New"
                                        Background="#E0E0E0"
                                        Foreground="#0B4F8A"
                                        BorderThickness="0"
                                        CornerRadius="8"
                                        HorizontalAlignment="Stretch"
                                        MinHeight="44"
                                        Padding="8,10"
                                        Click="QuickUpdateStatus_Click"/>
                                <Button Grid.Column="1"
                                        Content="Paid"
                                        Tag="Paid"
                                        Background="#F2CF93"
                                        Foreground="#6A4A00"
                                        BorderThickness="0"
                                        CornerRadius="8"
                                        HorizontalAlignment="Stretch"
                                        MinHeight="44"
                                        Padding="8,10"
                                        Click="QuickUpdateStatus_Click"/>
                                <Button Grid.Column="2"
                                        Content="Cancelled"
                                        Tag="Cancelled"
                                        Background="#FFD9D6"
                                        Foreground="#C62828"
                                        BorderThickness="0"
                                        CornerRadius="8"
                                        HorizontalAlignment="Stretch"
                                        MinHeight="44"
                                        Padding="8,10"
                                        Click="QuickUpdateStatus_Click"/>
                            </Grid>
                        </StackPanel>

                        <!-- Product Lines Header -->
                        <TextBlock Text="PRODUCTS"
                                   FontSize="11"
                                   CharacterSpacing="40"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"
                                   Margin="0,4,0,0"/>

                        <!-- Product Lines List -->
                        <ItemsControl ItemsSource="{x:Bind ViewModel.SelectedOrder.Lines, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:OrderDetailLineViewModel">
                                    <Border BorderBrush="#1AC0C7D4"
                                            BorderThickness="0,0,0,1"
                                            Padding="0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0"
                                                        Spacing="2">
                                                <TextBlock Text="{x:Bind ProductName}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                                                <TextBlock Text="{x:Bind UnitPriceDisplay}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind QtyDisplay}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"
                                                       Margin="12,0"
                                                       Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>

                                            <TextBlock Grid.Column="2"
                                                       Text="{x:Bind LineTotalDisplay}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- Sidebar Footer: Delete Button -->
                <Border Grid.Row="2"
                        Padding="24,16"
                        BorderBrush="#1AC0C7D4"
                        BorderThickness="0,1,0,0">
                    <Button x:Name="DeleteFromSidebarButton"
                            HorizontalAlignment="Stretch"
                            Background="#FFEBEE"
                            Foreground="{StaticResource FluentPlayErrorColor}"
                            BorderThickness="0"
                            CornerRadius="8"
                            Padding="12,10"
                            Click="DeleteOrder_Click">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <PathIcon Width="16"
                                      Height="16"
                                      Foreground="{StaticResource FluentPlayErrorColor}"
                                      Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/>
                            <TextBlock Text="Delete Order"
                                       FontSize="14"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
