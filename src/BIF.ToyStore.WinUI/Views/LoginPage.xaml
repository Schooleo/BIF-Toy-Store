<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BIF.ToyStore.WinUI.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:pages="using:BIF.ToyStore.ViewModels.Pages" d:DataContext="{d:DesignInstance Type=pages:LoginViewModel}"
    RequestedTheme="Light"
    mc:Ignorable="d">

    <Grid Background="{StaticResource LoginSurfaceBrush}">
        <Grid x:Name="BackgroundBlurHost" SizeChanged="BackgroundBlurHost_SizeChanged">
            <Rectangle Fill="{StaticResource LoginOverlayBrush}" />
        </Grid>

        <ScrollViewer VerticalScrollMode="Auto"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollMode="Disabled"
                      HorizontalScrollBarVisibility="Disabled"
                      ZoomMode="Disabled"
                      Padding="24">
            <Grid MinHeight="700" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="440" Spacing="20">
                    <Border CornerRadius="12"
                            Background="{StaticResource LoginGlassBrush}">
                        <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="32"
                            Background="Transparent"
                            CornerRadius="12,12,0,0">
                        <StackPanel Spacing="18">
                            <StackPanel HorizontalAlignment="Center" Spacing="6" Margin="0,0,0,6">
                                <Border Width="64" Height="64" CornerRadius="12" Background="{StaticResource LoginPrimaryBrush}" HorizontalAlignment="Center">
                                    <Viewbox Margin="14">
                                        <SymbolIcon Symbol="Home" Foreground="White" />
                                    </Viewbox>
                                </Border>
                                <TextBlock Text="Toy Workshop"
                                           FontSize="36"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource LoginTextBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Curated Excellence Management System"
                                           Foreground="{StaticResource LoginTextBrush}"
                                           Opacity="0.75"
                                           HorizontalAlignment="Center" />
                            </StackPanel>

                            <TextBlock Text="ACCOUNT ROLE"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       CharacterSpacing="140"
                                       Foreground="{StaticResource LoginTextBrush}" />
                            <ComboBox SelectedIndex="0"
                                      Style="{StaticResource AppInputComboBoxStyle}"
                                      CornerRadius="8,8,0,0"
                                      BorderThickness="0,0,0,2"
                                      Padding="14,10">
                                <ComboBox.Resources>
                                    <Style TargetType="ComboBoxItem" BasedOn="{StaticResource DefaultComboBoxItemStyle}">
                                        <Setter Property="Foreground" Value="{StaticResource LoginTextBrush}" />
                                        <Setter Property="Background" Value="{StaticResource LoginCardBrush}" />
                                    </Style>
                                </ComboBox.Resources>
                                <ComboBoxItem Content="Administrator" Foreground="{StaticResource LoginTextBrush}" Background="{StaticResource LoginCardBrush}" />
                                <ComboBoxItem Content="Salesperson" Foreground="{StaticResource LoginTextBrush}" Background="{StaticResource LoginCardBrush}" />
                            </ComboBox>

                            <TextBlock Text="USERNAME"
                                       Margin="0,6,0,0"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       CharacterSpacing="140"
                                       Foreground="{StaticResource LoginTextBrush}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        CornerRadius="8,0,0,0"
                                        Background="{StaticResource LoginCardBrush}"
                                        BorderBrush="{StaticResource LoginDividerBrush}"
                                        BorderThickness="0,0,0,2">
                                    <Viewbox Margin="14">
                                        <SymbolIcon Symbol="Contact" Foreground="{StaticResource LoginTextBrush}" />
                                    </Viewbox>
                                </Border>
                                <TextBox Grid.Column="1"
                                         Style="{StaticResource AppInputTextBoxStyle}"
                                         CornerRadius="0,8,0,0"
                                         BorderThickness="0,0,0,2"
                                         Padding="12,10"
                                         PlaceholderText="Enter your username"
                                         Text="{x:Bind ViewModel.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="PASSWORD"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           CharacterSpacing="140"
                                           Foreground="{StaticResource LoginTextBrush}" />

                                <HyperlinkButton Grid.Column="1"
                                                 Content="Forgot?"
                                                 Foreground="{StaticResource LoginPrimaryBrush}"
                                                 Padding="0"
                                                 MinWidth="0"
                                                 HorizontalAlignment="Right" />
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        CornerRadius="8,0,0,0"
                                        Background="{StaticResource LoginCardBrush}"
                                        BorderBrush="{StaticResource LoginDividerBrush}"
                                        BorderThickness="0,0,0,2">
                                    <Viewbox Margin="14">
                                        <FontIcon Glyph="&#xE72E;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource LoginTextBrush}" />
                                    </Viewbox>
                                </Border>
                                <PasswordBox x:Name="UserPasswordBox"
                                             Grid.Column="1"
                                             Style="{StaticResource AppInputPasswordBoxStyle}"
                                             CornerRadius="0,8,0,0"
                                             BorderThickness="0,0,0,2"
                                             Padding="12,10"
                                             Password="{x:Bind ViewModel.Password, Mode=TwoWay}" />
                            </Grid>

                            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                       TextWrapping="Wrap" />

                            <Button Command="{x:Bind ViewModel.LoginCommand}"
                                    Background="{StaticResource LoginPrimaryBrush}"
                                    Foreground="White"
                                    Height="48"
                                    HorizontalAlignment="Stretch"
                                    MinWidth="0"
                                    CornerRadius="8"
                                    Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                                    <TextBlock Text="Sign In" FontWeight="SemiBold" />
                                    <FontIcon Glyph="&#xE8FA;" FontFamily="Segoe MDL2 Assets" />
                                </StackPanel>
                            </Button>

                            <Border Height="1"
                                    Margin="0,10,0,2"
                                    Background="{StaticResource LoginDividerBrush}"
                                    Opacity="0.35" />

                            <TextBlock TextAlignment="Center" TextWrapping="Wrap" Foreground="{StaticResource LoginTextBrush}">
                                <Run Text="Don't have an account? " />
                                <Run Text="Contact Admin" Foreground="#005FAA" FontWeight="SemiBold" />
                            </TextBlock>

                            <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                                       HorizontalAlignment="Center"
                                       Opacity="0.6"
                                       FontSize="11"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>

                        <Border Grid.Row="1"
                            Background="{StaticResource LoginCardFooterBrush}"
                            Padding="24,16"
                            CornerRadius="0,0,12,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE946;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource LoginTextBrush}" />
                                <TextBlock Text="DEMO CREDENTIALS"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           CharacterSpacing="120"
                                           Foreground="{StaticResource LoginTextBrush}" />
                            </StackPanel>

                            <Grid Grid.Column="1" HorizontalAlignment="Right" ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Right">
                                    <TextBlock Text="Admin" FontSize="10" Opacity="0.65" HorizontalAlignment="Right" />
                                    <TextBlock Text="admin / admin123" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource LoginPrimaryBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <TextBlock Text="Sale" FontSize="10" Opacity="0.65" HorizontalAlignment="Right" />
                                    <TextBlock Text="sale1 / 123456" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource LoginPrimaryBrush}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                        </Grid>
                    </Border>

                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
                            <HyperlinkButton Content="Privacy Policy" Foreground="{StaticResource LoginTextBrush}" Opacity="0.85" />
                            <HyperlinkButton Content="Terms of Service" Foreground="{StaticResource LoginTextBrush}" Opacity="0.85" />
                            <HyperlinkButton Content="Support" Foreground="{StaticResource LoginTextBrush}" Opacity="0.85" />
                        </StackPanel>
                        <TextBlock Text="© 2024 TOY WORKSHOP MANAGEMENT SYSTEM"
                                   Foreground="{StaticResource LoginTextBrush}"
                                   Opacity="0.75"
                                   FontSize="10"
                                   CharacterSpacing="140"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
