<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BIF.ToyStore.WinUI.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BIF.ToyStore.WinUI.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
            <Image Source="ms-appx:///Assets/Branding/ToyBanner.jpg" Stretch="Fill" />
        </StackPanel>

        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="300" Spacing="15">
            <TextBlock Text="Sign In" 
                       Style="{ThemeResource HeaderTextBlockStyle}" 
                       Margin="0,0,0,10"
                       HorizontalAlignment="Center" />

            <TextBox Header="Username" 
                     Text="{x:Bind ViewModel.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <PasswordBox x:Name="UserPasswordBox" 
                         Header="Password" 
                         Password="{x:Bind ViewModel.Password, Mode=TwoWay}" />

            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" 
                       Foreground="{ThemeResource SystemFillColorCriticalBrush}" 
                       TextWrapping="Wrap" />

            <Button Content="Login" 
                    Command="{x:Bind ViewModel.LoginCommand}" 
                    Width="300" 
                    Style="{ThemeResource AccentButtonStyle}" />
        </StackPanel>
    </Grid>
</Page>
