<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BIF.ToyStore.WinUI.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:BIF.ToyStore.WinUI.Controls"
    xmlns:converters="using:BIF.ToyStore.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="using:BIF.ToyStore.ViewModels.Pages"
    x:Name="RootPage"
    RequestedTheme="Light"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="RestockPanelLabelStyle" TargetType="TextBlock">
            <Setter Property="CharacterSpacing" Value="100"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{ThemeResource FluentPlayOnSurfaceVariantBrush}"/>
        </Style>

        <Style x:Key="RestockPanelNumberBoxStyle" TargetType="NumberBox">
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="{ThemeResource FluentPlaySurfaceContainerLowBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource FluentPlayOutlineVariantBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{ThemeResource FluentPlayOnSurfaceBrush}"/>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource FluentPlaySurfaceBrush}">
        <ScrollViewer
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollMode="Auto"
            HorizontalScrollMode="Disabled">
            <Grid Padding="32"
                  RowSpacing="24"
                  HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Spacing="4">
                        <TextBlock Text="Workshop Overview"
                                   FontSize="30"
                                   FontWeight="ExtraBold"
                                   Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                        <TextBlock Text="Real-time performance metrics for Toy Store Management"
                                   FontSize="16"
                                   Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="12"
                                VerticalAlignment="Center">
                        <Button Content="Refresh"
                                Command="{x:Bind ViewModel.RefreshCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Padding="16,10">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver"
                                                 Color="{StaticResource FluentPlayPrimaryHoverColor}"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed"
                                                 Color="{StaticResource FluentPlayPrimaryPressedColor}"/>
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver"
                                                 Color="{StaticResource FluentPlayOnPrimaryColor}"/>
                                <SolidColorBrush x:Key="ButtonForegroundPressed"
                                                 Color="{StaticResource FluentPlayOnPrimaryColor}"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver"
                                                 Color="{StaticResource FluentPlayPrimaryHoverColor}"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPressed"
                                                 Color="{StaticResource FluentPlayPrimaryPressedColor}"/>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1"
                      ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="White"
                            CornerRadius="12"
                            BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                            BorderThickness="1"
                            Padding="24">
                        <StackPanel Spacing="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="TOTAL PRODUCTS"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           CharacterSpacing="120"
                                           Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                <Image Grid.Column="1"
                                       Source="ms-appx:///Assets/Icons/Product.svg"
                                       Width="18"
                                       Height="18"/>
                            </Grid>
                            <TextBlock Text="{x:Bind ViewModel.TotalProductsDisplay, Mode=OneWay}"
                                       FontSize="36"
                                       FontWeight="ExtraBold"
                                       Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6"
                                        VerticalAlignment="Center">
                                <Image Source="ms-appx:///Assets/Icons/Trend.svg"
                                       Width="14"
                                       Height="14"/>
                                <TextBlock Text="{x:Bind ViewModel.TotalProductsSubtext, Mode=OneWay}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource FluentPlayPrimaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="White"
                            CornerRadius="12"
                            BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                            BorderThickness="1"
                            Padding="24">
                        <StackPanel Spacing="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="TODAY'S REVENUE"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           CharacterSpacing="120"
                                           Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                <Image Grid.Column="1"
                                       Source="ms-appx:///Assets/Icons/Money.svg"
                                       Width="18"
                                       Height="18"/>
                            </Grid>
                            <TextBlock Text="{x:Bind ViewModel.TodayRevenueDisplay, Mode=OneWay}"
                                       FontSize="36"
                                       FontWeight="ExtraBold"
                                       Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6"
                                        VerticalAlignment="Center">
                                <Image Source="ms-appx:///Assets/Icons/Trend.svg"
                                       Width="14"
                                       Height="14"/>
                                <TextBlock Text="{x:Bind ViewModel.TodayRevenueSubtext, Mode=OneWay}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource FluentPlayPrimaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Background="White"
                            CornerRadius="12"
                            BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                            BorderThickness="1"
                            Padding="24">
                        <StackPanel Spacing="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="ORDERS TODAY"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           CharacterSpacing="120"
                                           Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                <Image Grid.Column="1"
                                       Source="ms-appx:///Assets/Icons/Order.svg"
                                       Width="18"
                                       Height="18"/>
                            </Grid>
                            <TextBlock Text="{x:Bind ViewModel.OrdersTodayDisplay, Mode=OneWay}"
                                       FontSize="36"
                                       FontWeight="ExtraBold"
                                       Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6"
                                        VerticalAlignment="Center">
                                <Image Source="ms-appx:///Assets/Icons/Trend.svg"
                                       Width="14"
                                       Height="14"/>
                                <TextBlock Text="{x:Bind ViewModel.OrdersTodaySubtext, Mode=OneWay}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource FluentPlayPrimaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="2"
                      ColumnSpacing="32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Spacing="24">
                        <Border Background="White"
                                CornerRadius="12"
                                BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                                BorderThickness="1"
                                Padding="24">
                            <Grid RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind ViewModel.RevenuePeriodLabel, Mode=OneWay}"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                                    <Border Grid.Column="1"
                                            Background="{StaticResource FluentPlayPrimaryFixedColor}"
                                            CornerRadius="8"
                                            Padding="12,4">
                                        <TextBlock Text="{x:Bind ViewModel.RevenuePeriodBadge, Mode=OneWay}"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource FluentPlayOnPrimaryFixedVariantColor}"/>
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="1"
                                      Height="260">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0"
                                                   Text="{x:Bind ViewModel.RevenueAxisMaxDisplay, Mode=OneWay}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Row="1"
                                                   Text="{x:Bind ViewModel.RevenueAxisMidDisplay, Mode=OneWay}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="2"
                                                   Text="0"
                                                   FontSize="10"
                                                   Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Bottom"/>
                                    </Grid>

                                    <Border Grid.Column="1"
                                            BorderBrush="#22C0C7D4"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      HorizontalScrollMode="Enabled"
                                                      VerticalScrollBarVisibility="Disabled"
                                                      VerticalScrollMode="Disabled"
                                                      ZoomMode="Disabled">
                                            <Grid Width="{x:Bind ViewModel.RevenueTrendScrollableWidth, Mode=OneWay}">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0"
                                                      Height="220"
                                                      Margin="0,0,0,4"
                                                      Background="#FFF8FAFC">
                                                    <Rectangle Height="1"
                                                               Fill="#33C0C7D4"
                                                               VerticalAlignment="Top"
                                                               Margin="0,12,0,0"/>
                                                    <Rectangle Height="1"
                                                               Fill="#33C0C7D4"
                                                               VerticalAlignment="Center"/>
                                                    <Rectangle Height="1"
                                                               Fill="#33C0C7D4"
                                                               VerticalAlignment="Bottom"
                                                               Margin="0,0,0,12"/>

                                                    <Path Data="{x:Bind ViewModel.RevenueTrendAreaData, Mode=OneWay}"
                                                          Fill="#35137BC6"
                                                          Stretch="None"/>
                                                    <Path Data="{x:Bind ViewModel.RevenueTrendPathData, Mode=OneWay}"
                                                          Stroke="#FF005FAA"
                                                          StrokeThickness="4"
                                                          StrokeLineJoin="Round"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          Stretch="None"/>

                                                    <ItemsControl ItemsSource="{x:Bind ViewModel.RevenueTrendMarkers, Mode=OneWay}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <Canvas/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="pages:RevenueTrendMarkerViewModel">
                                                                <Grid Width="18"
                                                                      Height="18"
                                                                      Background="Transparent"
                                                                      Canvas.Left="{x:Bind X}"
                                                                      Canvas.Top="{x:Bind Y}">
                                                                    <ToolTipService.ToolTip>
                                                                        <TextBlock Text="{x:Bind Tooltip}"/>
                                                                    </ToolTipService.ToolTip>
                                                                    <Ellipse Width="10"
                                                                             Height="10"
                                                                             Fill="White"
                                                                             Stroke="#FF005FAA"
                                                                             StrokeThickness="3"
                                                                             HorizontalAlignment="Center"
                                                                             VerticalAlignment="Center"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>

                                                <ItemsControl Grid.Row="1"
                                                              ItemsSource="{x:Bind ViewModel.RevenueTrendPoints, Mode=OneWay}"
                                                              Margin="0,4,0,6">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="pages:RevenueTrendPointViewModel">
                                                            <TextBlock Text="{x:Bind DayLabel}"
                                                                       Width="{x:Bind LabelWidth, Mode=OneWay}"
                                                                       FontSize="10"
                                                                       Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"
                                                                       TextAlignment="Center"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border
                            Background="White"
                            CornerRadius="12"
                            BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                            BorderThickness="1"
                            Padding="24">
                            <Grid RowSpacing="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Top 5 Low-Stock Products"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Background="#FFFFDBC8"
                                            CornerRadius="8"
                                            Padding="12,4">
                                        <TextBlock Text="Warning"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   Foreground="#FF743500"
                                                   CharacterSpacing="80"/>
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="1"
                                      ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1.3*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="1"
                                               Text="Product"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               CharacterSpacing="120"
                                               Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                    <TextBlock Grid.Column="2"
                                               Text="Category"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               CharacterSpacing="120"
                                               Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                    <TextBlock Grid.Column="3"
                                               Text="Stock"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               CharacterSpacing="120"
                                               Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="4"
                                               Text="Price"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               CharacterSpacing="120"
                                               Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"
                                               HorizontalAlignment="Right"/>
                                </Grid>

                                <ListView Grid.Row="2"
                                          x:Name="LowStockProductsList"
                                          x:Load="{x:Bind ViewModel.HasLowStockProducts, Mode=OneWay}"
                                          ItemsSource="{x:Bind ViewModel.LowStockProducts, Mode=OneWay}"
                                          SelectionMode="None"
                                          IsItemClickEnabled="False"
                                          HorizontalContentAlignment="Stretch"
                                          Padding="0"
                                          MinHeight="240">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="pages:LowStockProductViewModel">
                                            <Grid Padding="0,10"
                                                  ColumnSpacing="16"
                                                  BorderBrush="#22C0C7D4"
                                                  BorderThickness="0,0,0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="3*"/>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="1.3*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        Width="38"
                                                        Height="38"
                                                        CornerRadius="8"
                                                        Background="{StaticResource FluentPlaySurfaceContainerHighBrush}">
                                                    <Grid>
                                                        <Image Source="{x:Bind ImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}}"
                                                               Stretch="UniformToFill"/>
                                                    </Grid>
                                                </Border>

                                                <TextBlock Grid.Column="1"
                                                           Text="{x:Bind Name}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{x:Bind CategoryName}"
                                                           FontSize="14"
                                                           Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                                <TextBlock Grid.Column="3"
                                                           Text="{x:Bind StockQuantity}"
                                                           FontSize="13"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource FluentPlayOnSurfaceBrush}"
                                                           HorizontalAlignment="Right"/>
                                                <TextBlock Grid.Column="4"
                                                           Text="{x:Bind PriceDisplay}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource FluentPlayPrimaryBrush}"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <Border Grid.Row="2"
                                        x:Name="LowStockProductsEmptyState"
                                        x:Load="{x:Bind ViewModel.IsLowStockProductsEmpty, Mode=OneWay}"
                                        Background="{StaticResource FluentPlaySurfaceContainerLowBrush}"
                                        BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="16"
                                        MinHeight="120">
                                    <TextBlock Text="No low-stock products right now. Inventory levels look healthy."
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Spacing="24">
                        <Border Background="White"
                                CornerRadius="12"
                                BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                                BorderThickness="1"
                                Padding="24">
                            <Grid RowSpacing="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="Top 5 Best-Sellers"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>

                                <ItemsControl Grid.Row="1"
                                              x:Name="BestSellingProductsList"
                                              x:Load="{x:Bind ViewModel.HasBestSellingProducts, Mode=OneWay}"
                                              ItemsSource="{x:Bind ViewModel.BestSellingProducts, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="pages:BestSellingProductViewModel">
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Grid Grid.Column="0"
                                                      Margin="0,0,12,0">
                                                    <Border Width="64"
                                                            Height="64"
                                                            CornerRadius="8"
                                                            Background="{StaticResource FluentPlaySurfaceContainerHighBrush}">
                                                        <Grid>
                                                            <Image Source="{x:Bind ImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}}"
                                                                   Stretch="UniformToFill"/>
                                                        </Grid>
                                                    </Border>
                                                    <Border Width="20"
                                                            Height="20"
                                                            CornerRadius="10"
                                                            Background="#FFFDB700"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Top"
                                                            Margin="-6,-6,0,0">
                                                        <TextBlock Text="{x:Bind RankDisplay}"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="#FF6A4B00"/>
                                                    </Border>
                                                </Grid>

                                                <StackPanel Grid.Column="1"
                                                            Spacing="2"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind ProductName}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                                                    <TextBlock Text="{x:Bind CategoryName}"
                                                               FontSize="12"
                                                               Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                                    <TextBlock Text="{x:Bind PriceDisplay}"
                                                               FontSize="14"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource FluentPlayPrimaryBrush}"/>
                                                </StackPanel>

                                                <Border Grid.Column="2"
                                                        Background="{StaticResource FluentPlaySurfaceContainerHighBrush}"
                                                        CornerRadius="8"
                                                        Padding="8,4"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind SoldDisplay}"
                                                               FontSize="11"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource FluentPlayPrimaryBrush}"/>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border Grid.Row="1"
                                        x:Name="BestSellingProductsEmptyState"
                                        x:Load="{x:Bind ViewModel.IsBestSellingProductsEmpty, Mode=OneWay}"
                                        Background="{StaticResource FluentPlaySurfaceContainerLowBrush}"
                                        BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="16">
                                    <TextBlock Text="No best-seller data yet. Top-selling products will appear here once sales are recorded."
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Background="#FFFFDBC8"
                                BorderBrush="#33974700"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="20">
                            <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="10">
                                    <Image Source="ms-appx:///Assets/Icons/Info.svg"
                                           Width="18"
                                           Height="18"/>
                                    <TextBlock Text="INVENTORY ALERT"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="#FF743500"/>
                                </StackPanel>
                                <TextBlock Text="{x:Bind ViewModel.InventoryAlertSummary, Mode=OneWay}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Foreground="#FF311300"/>
                                <Button Content="QUICK RESTOCK"
                                        Background="#FF974700"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        Command="{x:Bind ViewModel.OpenQuickRestockPanelCommand}"
                                        HorizontalAlignment="Stretch">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver"
                                                         Color="{StaticResource FluentPlayOnTertiaryFixedVariantColor}"/>
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed"
                                                         Color="{StaticResource FluentPlayOnTertiaryFixedColor}"/>
                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver"
                                                         Color="{StaticResource FluentPlayOnTertiaryColor}"/>
                                        <SolidColorBrush x:Key="ButtonForegroundPressed"
                                                         Color="{StaticResource FluentPlayOnTertiaryColor}"/>
                                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver"
                                                         Color="{StaticResource FluentPlayOnTertiaryFixedVariantColor}"/>
                                        <SolidColorBrush x:Key="ButtonBorderBrushPressed"
                                                         Color="{StaticResource FluentPlayOnTertiaryFixedColor}"/>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>

                <Border Grid.Row="3"
                        Background="White"
                        CornerRadius="12"
                        BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                        BorderThickness="1"
                        Padding="24">
                    <Grid RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center">
                            <TextBlock Text="3 Most Recent Orders"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                        </StackPanel>

                        <ItemsControl Grid.Row="1"
                                      x:Name="RecentOrdersList"
                                      x:Load="{x:Bind ViewModel.HasRecentOrders, Mode=OneWay}"
                                      ItemsSource="{x:Bind ViewModel.RecentOrders, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="16"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="pages:RecentOrderViewModel">
                                    <Border Width="370"
                                            Background="{StaticResource FluentPlaySurfaceContainerLowBrush}"
                                            BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="18">
                                        <StackPanel Spacing="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{x:Bind OrderIdDisplay}"
                                                           FontSize="14"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{x:Bind Status}"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           CharacterSpacing="70"
                                                           Foreground="{StaticResource FluentPlayPrimaryBrush}"/>
                                            </Grid>
                                            <TextBlock Text="{x:Bind CustomerName}"
                                                       FontSize="13"
                                                       Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                            <TextBlock Text="{x:Bind ItemCountDisplay}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{x:Bind TotalAmountDisplay}"
                                                           FontSize="16"
                                                           FontWeight="ExtraBold"
                                                           Foreground="{StaticResource FluentPlayPrimaryBrush}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{x:Bind RelativeTimeDisplay}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"
                                                           VerticalAlignment="Bottom"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Grid.Row="1"
                                x:Name="RecentOrdersEmptyState"
                                x:Load="{x:Bind ViewModel.IsRecentOrdersEmpty, Mode=OneWay}"
                                Background="{StaticResource FluentPlaySurfaceContainerLowBrush}"
                                BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="16">
                            <TextBlock Text="No recent orders yet. New orders will show up here as soon as they are created."
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                        </Border>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="4"
                           Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                           TextWrapping="WrapWholeWords"/>

                <controls:AppFooter Grid.Row="5"
                                    Margin="0,8,0,0"/>
            </Grid>
        </ScrollViewer>

        <Grid Background="#66000000"
              Visibility="{x:Bind ViewModel.IsQuickRestockPanelOpen, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Width="430"
                    MinWidth="430"
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Right"
                    Background="{ThemeResource FluentPlaySurfaceBrush}"
                    BorderBrush="{ThemeResource FluentPlayOutlineVariantBrush}"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="22,20"
                            BorderBrush="{ThemeResource FluentPlayOutlineVariantBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="3">
                                <TextBlock Text="Quick Restock"
                                           FontSize="30"
                                           FontWeight="ExtraBold"
                                           Foreground="{ThemeResource FluentPlayOnSurfaceBrush}"/>
                                <TextBlock Text="Update stock levels for low-stock products."
                                           FontSize="16"
                                           TextWrapping="Wrap"
                                           Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Width="36"
                                    Height="36"
                                    Padding="0"
                                    Background="{ThemeResource FluentPlaySurfaceContainerLowBrush}"
                                    BorderBrush="{ThemeResource FluentPlayOutlineVariantBrush}"
                                    Command="{x:Bind ViewModel.CancelQuickRestockPanelCommand}"
                                    CornerRadius="18">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver"
                                                     Color="{StaticResource FluentPlaySurfaceContainerHighColor}"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed"
                                                     Color="{StaticResource FluentPlaySurfaceVariantColor}"/>
                                </Button.Resources>
                                <FontIcon Glyph="&#xE711;"
                                          FontSize="12"
                                          Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}"/>
                            </Button>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  VerticalScrollMode="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  HorizontalScrollMode="Disabled">
                        <StackPanel Padding="22,18,22,20"
                                    Spacing="14">
                            <InfoBar IsClosable="False"
                                     IsOpen="{x:Bind ViewModel.HasQuickRestockErrorMessage, Mode=OneWay}"
                                     Message="{x:Bind ViewModel.QuickRestockErrorMessage, Mode=OneWay}"
                                     Severity="Error"/>

                            <TextBlock Style="{StaticResource RestockPanelLabelStyle}"
                                       Text="LOW-STOCK ITEMS"/>

                            <ItemsControl x:Name="QuickRestockItemsList"
                                          x:Load="{x:Bind ViewModel.HasQuickRestockItems, Mode=OneWay}"
                                          ItemsSource="{x:Bind ViewModel.QuickRestockItems, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="pages:QuickRestockProductViewModel">
                                        <Border Margin="0,0,0,12"
                                                Padding="14"
                                                Background="{ThemeResource FluentPlaySurfaceContainerLowestBrush}"
                                                BorderBrush="{ThemeResource FluentPlayOutlineVariantBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                            <Grid RowSpacing="12">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Width="48"
                                                            Height="48"
                                                            CornerRadius="10"
                                                            Background="{ThemeResource FluentPlaySurfaceContainerHighBrush}">
                                                        <Image Source="{x:Bind ImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}}"
                                                               Stretch="UniformToFill"/>
                                                    </Border>

                                                    <StackPanel Grid.Column="1"
                                                                Spacing="3"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                                                   FontSize="15"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Foreground="{ThemeResource FluentPlayOnSurfaceBrush}"/>
                                                        <TextBlock Text="{x:Bind CategoryName, Mode=OneWay}"
                                                                   FontSize="12"
                                                                   Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}"/>
                                                        <TextBlock Text="{x:Bind PriceDisplay, Mode=OneWay}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{ThemeResource FluentPlayPrimaryBrush}"/>
                                                    </StackPanel>
                                                </Grid>

                                                <Grid Grid.Row="1"
                                                      ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="130"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Spacing="3"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="{x:Bind OriginalStockDisplay, Mode=OneWay}"
                                                                   FontSize="12"
                                                                   Foreground="{ThemeResource FluentPlayOnSurfaceVariantBrush}"/>
                                                        <Border Background="#FFFFDBC8"
                                                                CornerRadius="7"
                                                                Padding="8,3"
                                                                HorizontalAlignment="Left">
                                                            <TextBlock Text="{x:Bind StockDeltaDisplay, Mode=OneWay}"
                                                                       FontSize="11"
                                                                       FontWeight="Bold"
                                                                       Foreground="#FF743500"/>
                                                        </Border>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1"
                                                                Spacing="6">
                                                        <TextBlock Style="{StaticResource RestockPanelLabelStyle}"
                                                                   Text="NEW STOCK"/>
                                                        <NumberBox Minimum="0"
                                                                   SpinButtonPlacementMode="Compact"
                                                                   Style="{StaticResource RestockPanelNumberBoxStyle}"
                                                                   Value="{x:Bind StockQuantity, Mode=TwoWay}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border x:Name="QuickRestockEmptyState"
                                    x:Load="{x:Bind ViewModel.IsQuickRestockItemsEmpty, Mode=OneWay}"
                                    Background="{StaticResource FluentPlaySurfaceContainerLowBrush}"
                                    BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="16">
                                <TextBlock Text="No low-stock products are available to restock right now."
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2"
                            Padding="22,14,22,20"
                            BorderBrush="{ThemeResource FluentPlayOutlineVariantBrush}"
                            BorderThickness="0,1,0,0">
                        <StackPanel HorizontalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="14">
                            <Button Height="42"
                                    MinWidth="132"
                                    Padding="22,0"
                                    Background="{ThemeResource FluentPlaySurfaceContainerLowBrush}"
                                    BorderBrush="{ThemeResource FluentPlayOutlineVariantBrush}"
                                    Command="{x:Bind ViewModel.CancelQuickRestockPanelCommand}"
                                    Content="Cancel">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver"
                                                     Color="{StaticResource FluentPlaySurfaceContainerHighColor}"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed"
                                                     Color="{StaticResource FluentPlaySurfaceVariantColor}"/>
                                </Button.Resources>
                            </Button>

                            <Button Height="42"
                                    MinWidth="132"
                                    Padding="22,0"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    Command="{x:Bind ViewModel.SaveQuickRestockCommand}"
                                    Content="Save"
                                    FontWeight="Bold">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver"
                                                     Color="{StaticResource FluentPlayPrimaryHoverColor}"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed"
                                                     Color="{StaticResource FluentPlayPrimaryPressedColor}"/>
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver"
                                                     Color="{StaticResource FluentPlayOnPrimaryColor}"/>
                                    <SolidColorBrush x:Key="ButtonForegroundPressed"
                                                     Color="{StaticResource FluentPlayOnPrimaryColor}"/>
                                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver"
                                                     Color="{StaticResource FluentPlayPrimaryHoverColor}"/>
                                    <SolidColorBrush x:Key="ButtonBorderBrushPressed"
                                                     Color="{StaticResource FluentPlayPrimaryPressedColor}"/>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
