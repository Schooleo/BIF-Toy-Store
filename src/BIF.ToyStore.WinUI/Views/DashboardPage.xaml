<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BIF.ToyStore.WinUI.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="using:BIF.ToyStore.ViewModels.Pages"
    x:Name="RootPage"
    RequestedTheme="Light"
    mc:Ignorable="d">

    <Grid Background="{StaticResource FluentPlaySurfaceBrush}">
        <ScrollViewer
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollMode="Auto"
                      HorizontalScrollMode="Disabled">
            <Grid Padding="32" RowSpacing="24" MaxWidth="1280" HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Workshop Overview"
                                   FontSize="30"
                                   FontWeight="ExtraBold"
                                   Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                        <TextBlock Text="Real-time performance metrics for Toy Store Management"
                                   FontSize="16"
                                   Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Button Content="Refresh"
                                Command="{x:Bind ViewModel.RefreshCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Padding="16,10">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource FluentPlayPrimaryHoverColor}" />
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource FluentPlayPrimaryPressedColor}" />
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource FluentPlayOnPrimaryColor}" />
                                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource FluentPlayOnPrimaryColor}" />
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="{StaticResource FluentPlayPrimaryHoverColor}" />
                                <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="{StaticResource FluentPlayPrimaryPressedColor}" />
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="White"
                            CornerRadius="12"
                            BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                            BorderThickness="1"
                            Padding="24">
                        <StackPanel Spacing="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="TOTAL PRODUCTS"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           CharacterSpacing="120"
                                           Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                                <Image Grid.Column="1"
                                       Source="ms-appx:///Assets/Icons/Product.svg"
                                       Width="18"
                                       Height="18" />
                            </Grid>
                            <TextBlock Text="{x:Bind ViewModel.TotalProductsDisplay, Mode=OneWay}"
                                       FontSize="36"
                                       FontWeight="ExtraBold"
                                       Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.TotalProductsSubtext, Mode=OneWay}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource FluentPlayPrimaryBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="White"
                            CornerRadius="12"
                            BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                            BorderThickness="1"
                            Padding="24">
                        <StackPanel Spacing="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="TODAY'S REVENUE"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           CharacterSpacing="120"
                                       Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                                <Image Grid.Column="1"
                                       Source="ms-appx:///Assets/Icons/Money.svg"
                                       Width="18"
                                       Height="18" />
                            </Grid>
                            <TextBlock Text="{x:Bind ViewModel.TodayRevenueDisplay, Mode=OneWay}"
                                       FontSize="36"
                                       FontWeight="ExtraBold"
                                       Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.TodayRevenueSubtext, Mode=OneWay}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource FluentPlayPrimaryBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Background="White"
                            CornerRadius="12"
                            BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                            BorderThickness="1"
                            Padding="24">
                        <StackPanel Spacing="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="ORDERS TODAY"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           CharacterSpacing="120"
                                           Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                                <Image Grid.Column="1"
                                       Source="ms-appx:///Assets/Icons/Order.svg"
                                       Width="18"
                                       Height="18" />
                            </Grid>
                            <TextBlock Text="{x:Bind ViewModel.OrdersTodayDisplay, Mode=OneWay}"
                                       FontSize="36"
                                       FontWeight="ExtraBold"
                                       Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.OrdersTodaySubtext, Mode=OneWay}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource FluentPlayPrimaryBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="2" ColumnSpacing="32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="24">
                        <Border Background="White"
                                CornerRadius="12"
                                BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                                BorderThickness="1"
                                Padding="24">
                            <Grid RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Daily Revenue (March 2026)"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                                    <Border Grid.Column="1"
                                            Background="{StaticResource FluentPlayPrimaryFixedColor}"
                                            CornerRadius="8"
                                            Padding="12,4">
                                        <TextBlock Text="CURRENT MONTH"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource FluentPlayOnPrimaryFixedVariantColor}" />
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="1" Height="260">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="{x:Bind ViewModel.RevenueAxisMaxDisplay, Mode=OneWay}" FontSize="10" Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" HorizontalAlignment="Right" />
                                        <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.RevenueAxisMidDisplay, Mode=OneWay}" FontSize="10" Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="2" Text="0" FontSize="10" Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" HorizontalAlignment="Right" VerticalAlignment="Bottom" />
                                    </Grid>

                                    <Border Grid.Column="1" BorderBrush="#22C0C7D4" BorderThickness="1" CornerRadius="8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Viewbox Grid.Row="0" Stretch="Fill">
                                                <Grid Width="1000" Height="260">
                                                    <Path Data="{x:Bind ViewModel.RevenueTrendAreaData, Mode=OneWay}"
                                                          Fill="#25005FAA"
                                                          Stretch="Fill" />
                                                    <Path Data="{x:Bind ViewModel.RevenueTrendPathData, Mode=OneWay}"
                                                          Stroke="#FF005FAA"
                                                          StrokeThickness="4"
                                                          StrokeLineJoin="Round"
                                                          Stretch="Fill" />
                                                </Grid>
                                            </Viewbox>

                                            <ItemsControl Grid.Row="1" ItemsSource="{x:Bind ViewModel.RevenueTrendPoints, Mode=OneWay}" Margin="8,4,8,6">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="pages:RevenueTrendPointViewModel">
                                                        <TextBlock Text="{x:Bind DayLabel}"
                                                                   Width="44"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border
                            Background="White"
                            CornerRadius="12"
                            BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                            BorderThickness="1"
                            Padding="24">
                        <Grid RowSpacing="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="Top 5 Low-Stock Products"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                                </StackPanel>
                                <Border Grid.Column="1"
                                    Background="#FFFFDBC8"
                                        CornerRadius="8"
                                        Padding="12,4">
                                    <TextBlock Text="Warning"
                                               FontSize="10"
                                               FontWeight="Bold"
                                           Foreground="#FF743500"
                                               CharacterSpacing="80" />
                                </Border>
                            </Grid>

                            <Grid Grid.Row="1" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1.3*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Product" FontSize="11" FontWeight="Bold" CharacterSpacing="120" Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                                <TextBlock Grid.Column="1" Text="Category" FontSize="11" FontWeight="Bold" CharacterSpacing="120" Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                                <TextBlock Grid.Column="2" Text="Stock" FontSize="11" FontWeight="Bold" CharacterSpacing="120" Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" HorizontalAlignment="Right" />
                                <TextBlock Grid.Column="3" Text="Price" FontSize="11" FontWeight="Bold" CharacterSpacing="120" Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" HorizontalAlignment="Right" />
                            </Grid>

                            <ListView Grid.Row="2"
                                      ItemsSource="{x:Bind ViewModel.LowStockProducts, Mode=OneWay}"
                                      SelectionMode="None"
                                      IsItemClickEnabled="False"
                                      HorizontalContentAlignment="Stretch"
                                      Padding="0"
                                      MinHeight="240">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="pages:LowStockProductViewModel">
                                        <Grid Padding="0,10" ColumnSpacing="16" BorderBrush="#22C0C7D4" BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3*" />
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="1*" />
                                                <ColumnDefinition Width="1.3*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Bind Name}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind CategoryName}" FontSize="14" Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                                            <TextBlock Grid.Column="2" Text="{x:Bind StockQuantity}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource FluentPlayOnSurfaceBrush}" HorizontalAlignment="Right" />
                                            <TextBlock Grid.Column="3" Text="{x:Bind PriceDisplay}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource FluentPlayPrimaryBrush}" HorizontalAlignment="Right" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="24">
                        <Border Background="White"
                                CornerRadius="12"
                                BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                                BorderThickness="1"
                                Padding="24">
                            <Grid RowSpacing="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="Top 5 Best-Sellers"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />

                                <ItemsControl Grid.Row="1" ItemsSource="{x:Bind ViewModel.BestSellingProducts, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="pages:BestSellingProductViewModel">
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Grid Grid.Column="0" Margin="0,0,12,0">
                                                    <Border Width="64" Height="64" CornerRadius="8" Background="{StaticResource FluentPlaySurfaceContainerHighBrush}">
                                                        <Image Source="ms-appx:///Assets/Icons/Product.svg" Width="24" Height="24" />
                                                    </Border>
                                                    <Border Width="20" Height="20" CornerRadius="10" Background="#FFFDB700" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-6,-6,0,0">
                                                        <TextBlock Text="{x:Bind RankDisplay}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FF6A4B00" />
                                                    </Border>
                                                </Grid>

                                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind ProductName}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                                                    <TextBlock Text="{x:Bind CategoryName}" FontSize="12" Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                                                    <TextBlock Text="{x:Bind PriceDisplay}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource FluentPlayPrimaryBrush}" />
                                                </StackPanel>

                                                <Border Grid.Column="2" Background="{StaticResource FluentPlaySurfaceContainerHighBrush}" CornerRadius="8" Padding="8,4" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind SoldDisplay}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource FluentPlayPrimaryBrush}" />
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>

                        <Border Background="#FFFFDBC8"
                                BorderBrush="#33974700"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="20">
                            <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Image Source="ms-appx:///Assets/Icons/Info.svg" Width="18" Height="18" />
                                    <TextBlock Text="INVENTORY ALERT"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="#FF743500" />
                                </StackPanel>
                                <TextBlock Text="{x:Bind ViewModel.InventoryAlertSummary, Mode=OneWay}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Foreground="#FF311300" />
                                <Button Content="QUICK RESTOCK"
                                        Background="#FF974700"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>

                <Border Grid.Row="3"
                        Background="White"
                        CornerRadius="12"
                        BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                        BorderThickness="1"
                        Padding="24">
                    <Grid RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="3 Most Recent Orders"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                        </StackPanel>

                        <ItemsControl Grid.Row="1" ItemsSource="{x:Bind ViewModel.RecentOrders, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="16" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="pages:RecentOrderViewModel">
                                        <Border Width="370"
                                            Background="{StaticResource FluentPlaySurfaceContainerLowBrush}"
                                            BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="18">
                                        <StackPanel Spacing="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{x:Bind OrderIdDisplay}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                                                <TextBlock Grid.Column="1" Text="{x:Bind Status}" FontSize="11" FontWeight="Bold" CharacterSpacing="70" Foreground="{StaticResource FluentPlayPrimaryBrush}" />
                                            </Grid>
                                            <TextBlock Text="{x:Bind CustomerName}" FontSize="13" Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                                            <TextBlock Text="{x:Bind ItemCountDisplay}" FontSize="12" Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{x:Bind TotalAmountDisplay}" FontSize="16" FontWeight="ExtraBold" Foreground="{StaticResource FluentPlayPrimaryBrush}" />
                                                <TextBlock Grid.Column="1" Text="{x:Bind RelativeTimeDisplay}" FontSize="12" Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" VerticalAlignment="Bottom" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="4"
                           Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                           TextWrapping="WrapWholeWords" />
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
