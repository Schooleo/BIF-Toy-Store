<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BIF.ToyStore.WinUI.Views.UsersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="using:BIF.ToyStore.ViewModels.Pages"
    x:Name="RootPage"
    RequestedTheme="Light"
    mc:Ignorable="d">

    <Grid Background="#FFF9F9F9">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FFF3F3F3" BorderBrush="#FFC0C7D4" BorderThickness="0,0,1,0">
            <StackPanel Margin="20,24" Spacing="18">
                <TextBlock Text="Toy Workshop" FontSize="28" FontWeight="Bold" Foreground="#FF1A1C1C" />
                <TextBlock Text="CURATED EXCELLENCE" FontSize="12" CharacterSpacing="120" Foreground="#FF404752" />

                <StackPanel Margin="0,20,0,0" Spacing="10">
                    <Button Content="Dashboard" HorizontalAlignment="Stretch" Click="DashboardButton_Click" />
                    <Button Content="POS" HorizontalAlignment="Stretch" />
                    <Button Content="Products" HorizontalAlignment="Stretch" Background="#FFD3E3FF" Foreground="#FF004883" />
                    <Button Content="Orders" HorizontalAlignment="Stretch" />
                    <Button Content="Reports" HorizontalAlignment="Stretch" />
                    <Button Content="Settings" HorizontalAlignment="Stretch" />
                </StackPanel>

                <StackPanel VerticalAlignment="Bottom" Margin="0,340,0,0" Spacing="8">
                    <Button Content="Profile" HorizontalAlignment="Stretch" />
                    <Button Content="Logout" HorizontalAlignment="Stretch" Foreground="#FFBA1A1A" />
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      HorizontalScrollMode="Disabled">
            <Grid Padding="28" RowSpacing="20" MaxWidth="1120">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Staff Directory" FontSize="42" FontWeight="Bold" Foreground="#FF1A1C1C" />
                        <TextBlock Text="Manage workshop access and administrative roles." FontSize="16" Foreground="#FF404752" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Add New User"
                            Background="#FF005FAA"
                            Foreground="White"
                            Padding="20,10"
                            CornerRadius="8"
                            VerticalAlignment="Center" />
                </Grid>

                <Grid Grid.Row="1" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20" BorderBrush="#1AC0C7D4" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="TOTAL STAFF" FontSize="12" FontWeight="Bold" Foreground="#FF404752" CharacterSpacing="140" />
                            <TextBlock Text="{x:Bind ViewModel.TotalStaff, Mode=OneWay}" FontSize="40" FontWeight="Bold" Foreground="#FF1A1C1C" />
                            <TextBlock Text="Sorted by KPI desc" FontSize="14" Foreground="#FF16A34A" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20" BorderBrush="#1AC0C7D4" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="ADMINS" FontSize="12" FontWeight="Bold" Foreground="#FF404752" CharacterSpacing="140" />
                            <TextBlock Text="{x:Bind ViewModel.Admins, Mode=OneWay}" FontSize="40" FontWeight="Bold" Foreground="#FF1A1C1C" />
                            <TextBlock Text="Full system access" FontSize="14" Foreground="#FF404752" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="20" BorderBrush="#1AC0C7D4" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="ACTIVE SESSIONS" FontSize="12" FontWeight="Bold" Foreground="#FF404752" CharacterSpacing="140" />
                            <TextBlock Text="{x:Bind ViewModel.ActiveSessions, Mode=OneWay}" FontSize="40" FontWeight="Bold" Foreground="#FF1A1C1C" />
                            <TextBlock Text="KPI &gt;= 80" FontSize="14" Foreground="#FF16A34A" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="2" RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Filter by name (A-Z)"
                                   VerticalAlignment="Center"
                                   Foreground="#FF404752"
                                   FontWeight="SemiBold" />

                        <ComboBox Grid.Column="1"
                                  Width="150"
                                  HorizontalAlignment="Right"
                                  ItemsSource="{x:Bind ViewModel.NameFilters, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedNameFilter, Mode=TwoWay}" />
                    </Grid>

                    <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="0,8,0,8" BorderBrush="#1AC0C7D4" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Padding="20,10" Background="#80F3F3F3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3.4*" />
                                    <ColumnDefinition Width="1.5*" />
                                    <ColumnDefinition Width="2.2*" />
                                    <ColumnDefinition Width="1.3*" />
                                    <ColumnDefinition Width="1.2*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="USERNAME" FontSize="11" FontWeight="Bold" CharacterSpacing="120" Foreground="#FF404752" />
                                <TextBlock Grid.Column="1" Text="ROLE" FontSize="11" FontWeight="Bold" CharacterSpacing="120" Foreground="#FF404752" />
                                <TextBlock Grid.Column="2" Text="PASSWORD" FontSize="11" FontWeight="Bold" CharacterSpacing="120" Foreground="#FF404752" />
                                <TextBlock Grid.Column="3" Text="KPI" FontSize="11" FontWeight="Bold" CharacterSpacing="120" Foreground="#FF404752" />
                                <TextBlock Grid.Column="4" Text="ACTIONS" FontSize="11" FontWeight="Bold" CharacterSpacing="120" Foreground="#FF404752" HorizontalAlignment="Right" />
                            </Grid>

                            <Grid Grid.Row="1" Padding="16,8,16,0" RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3.4*" />
                                    <ColumnDefinition Width="1.5*" />
                                    <ColumnDefinition Width="2.2*" />
                                    <ColumnDefinition Width="1.3*" />
                                    <ColumnDefinition Width="1.2*" />
                                </Grid.ColumnDefinitions>

                                <ListView Grid.Row="0"
                                          Grid.ColumnSpan="5"
                                          ItemsSource="{x:Bind ViewModel.VisibleUsers, Mode=OneWay}"
                                          SelectionMode="None"
                                          IsItemClickEnabled="False"
                                          HorizontalContentAlignment="Stretch">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="pages:UserItemViewModel">
                                            <Grid Padding="8,10" BorderBrush="#1AC0C7D4" BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3.4*" />
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="2.2*" />
                                                <ColumnDefinition Width="1.3*" />
                                                <ColumnDefinition Width="1.2*" />
                                            </Grid.ColumnDefinitions>

                                            <Grid Grid.Column="0" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="32" Height="32" CornerRadius="16" Background="#FFD3E3FF">
                                                    <TextBlock Text="{x:Bind Initials, Mode=OneWay}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FF004883" FontWeight="Bold" />
                                                </Border>
                                                <TextBlock Grid.Column="1"
                                                           Text="{x:Bind Username, Mode=OneWay}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Left"
                                                           TextAlignment="Left"
                                                           Margin="10,0,0,0" />
                                            </Grid>

                                            <Border Grid.Column="1" Background="#1A005FAA" CornerRadius="999" Padding="10,4" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,4,0,0">
                                                <TextBlock Text="{x:Bind RoleLabel, Mode=OneWay}" Foreground="#FF005FAA" FontSize="10" FontWeight="Bold" CharacterSpacing="90" />
                                            </Border>

                                            <Grid Grid.Column="2" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <ScrollViewer Grid.Column="0"
                                                              HorizontalScrollMode="Enabled"
                                                              HorizontalScrollBarVisibility="Auto"
                                                              VerticalScrollMode="Disabled"
                                                              VerticalScrollBarVisibility="Hidden"
                                                              ZoomMode="Disabled"
                                                              Margin="0,0,8,0">
                                                    <TextBlock Text="{x:Bind PasswordDisplay, Mode=OneWay}"
                                                               FontSize="18"
                                                               Foreground="#FF404752"
                                                               TextWrapping="NoWrap" />
                                                </ScrollViewer>
                                                <Button Command="{Binding ViewModel.TogglePasswordCommand, ElementName=RootPage}"
                                                        Grid.Column="1"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Padding="0"
                                                        ToolTipService.ToolTip="Show/Hide password">
                                                    <SymbolIcon Symbol="View" />
                                                </Button>
                                            </Grid>

                                            <TextBlock Grid.Column="3" Text="{x:Bind Kpi, Mode=OneWay}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="16,0,0,0" />

                                            <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                                <Button Background="Transparent" BorderThickness="0" Padding="0"><SymbolIcon Symbol="Edit" /></Button>
                                                <Button Background="Transparent" BorderThickness="0" Padding="0"><SymbolIcon Symbol="Delete" /></Button>
                                            </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="3" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#1AD3E3FF" BorderBrush="#33A3C9FF" BorderThickness="1" CornerRadius="8" Padding="14">
                        <StackPanel Spacing="4">
                            <TextBlock Text="SECURITY AUDIT" FontWeight="Bold" Foreground="#FF004883" CharacterSpacing="100" />
                            <TextBlock Text="All administrative actions are logged in the system vault. Password visibility toggles are restricted to managers only." TextWrapping="Wrap" Foreground="#FF404752" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#1AFFF2E6" BorderBrush="#33FDB700" BorderThickness="1" CornerRadius="8" Padding="14">
                        <StackPanel Spacing="4">
                            <TextBlock Text="CRITICAL UPDATE" FontWeight="Bold" Foreground="#FF6A4B00" CharacterSpacing="100" />
                            <TextBlock Text="2 staff members have not updated their credentials in over 90 days. Forced reset may be required." TextWrapping="Wrap" Foreground="#FF404752" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
