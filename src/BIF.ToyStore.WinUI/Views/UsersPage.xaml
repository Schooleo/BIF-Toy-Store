<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BIF.ToyStore.WinUI.Views.UsersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:BIF.ToyStore.WinUI.Controls"
    xmlns:converters="using:BIF.ToyStore.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="using:BIF.ToyStore.ViewModels.Pages"
    x:Name="RootPage"
    RequestedTheme="Light"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid Background="{StaticResource FluentPlaySurfaceBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      HorizontalScrollMode="Disabled">
            <Grid Padding="32" RowSpacing="24" HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Staff Directory"
                                   FontSize="30"
                                   FontWeight="ExtraBold"
                                   Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                        <TextBlock Text="Manage workshop access and administrative roles."
                                   FontSize="16"
                                   Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Add New User"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Padding="16,10"
                            Click="AddNewUserButton_Click"
                            VerticalAlignment="Center">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource FluentPlayPrimaryHoverColor}" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource FluentPlayPrimaryPressedColor}" />
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource FluentPlayOnPrimaryColor}" />
                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource FluentPlayOnPrimaryColor}" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="{StaticResource FluentPlayPrimaryHoverColor}" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="{StaticResource FluentPlayPrimaryPressedColor}" />
                        </Button.Resources>
                    </Button>
                </Grid>

                <Grid Grid.Row="1" ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="White"
                            CornerRadius="12"
                            Padding="24"
                            BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="12">
                            <TextBlock Text="TOTAL STAFF" FontSize="11" FontWeight="Bold" CharacterSpacing="120" Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.TotalStaff, Mode=OneWay}" FontSize="36" FontWeight="ExtraBold" Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                            <TextBlock Text="Directory overview" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource FluentPlayPrimaryBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="White"
                            CornerRadius="12"
                            Padding="24"
                            BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="12">
                            <TextBlock Text="ADMINS" FontSize="11" FontWeight="Bold" CharacterSpacing="120" Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.Admins, Mode=OneWay}" FontSize="36" FontWeight="ExtraBold" Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                            <TextBlock Text="Full system access" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                        </StackPanel>
                    </Border>

                </Grid>

                <Border Grid.Row="2"
                        Background="White"
                        CornerRadius="12"
                        BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                        BorderThickness="1"
                        Padding="24">
                    <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Filter by name (A-Z)"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"
                                   FontWeight="SemiBold" />

                        <Button Grid.Column="1"
                                Background="White"
                                BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12,7"
                                HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <PathIcon Width="14" Height="14"
                                          Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"
                                          Data="M0 3H16V5H0V3ZM2 7H14V9H2V7ZM5 11H11V13H5V11Z" />
                                <TextBlock Text="{x:Bind ViewModel.SelectedNameFilter, Mode=OneWay}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                            </StackPanel>
                            <Button.Flyout>
                                <Flyout>
                                    <StackPanel Spacing="4" MinWidth="180">
                                        <TextBlock Text="FILTER BY NAME"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   CharacterSpacing="100"
                                                   Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"
                                                   Margin="0,0,0,6" />
                                        <ListView ItemsSource="{x:Bind ViewModel.NameFilters, Mode=OneWay}"
                                                  SelectedItem="{x:Bind ViewModel.SelectedNameFilter, Mode=TwoWay}"
                                                  SelectionMode="Single"
                                                  SelectionChanged="NameFilter_SelectionChanged"
                                                  BorderThickness="0"
                                                  Background="Transparent">
                                            <ListView.ItemContainerStyle>
                                                <Style TargetType="ListViewItem">
                                                    <Setter Property="Padding" Value="8,4" />
                                                    <Setter Property="MinHeight" Value="32" />
                                                </Style>
                                            </ListView.ItemContainerStyle>
                                        </ListView>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>

                    <Border Grid.Row="1"
                            Background="White"
                            CornerRadius="12"
                            BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Padding="20,12" Background="{StaticResource FluentPlaySurfaceContainerLowBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3.8*" />
                                    <ColumnDefinition Width="1.6*" />
                                    <ColumnDefinition Width="2.8*" />
                                    <ColumnDefinition Width="1.2*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="USERNAME" FontSize="11" FontWeight="Bold" CharacterSpacing="120" Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                                <TextBlock Grid.Column="1" Text="ROLE" FontSize="11" FontWeight="Bold" CharacterSpacing="120" Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                                <TextBlock Grid.Column="2" Text="PASSWORD" FontSize="11" FontWeight="Bold" CharacterSpacing="120" Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                                <TextBlock Grid.Column="3" Text="ACTIONS" FontSize="11" FontWeight="Bold" CharacterSpacing="120" Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" HorizontalAlignment="Right" />
                            </Grid>

                            <Grid Grid.Row="1" Padding="16,8,16,0" RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3.8*" />
                                    <ColumnDefinition Width="1.6*" />
                                    <ColumnDefinition Width="2.8*" />
                                    <ColumnDefinition Width="1.2*" />
                                </Grid.ColumnDefinitions>

                                <ListView Grid.Row="0"
                                          Grid.ColumnSpan="4"
                                          ItemsSource="{x:Bind ViewModel.VisibleUsers, Mode=OneWay}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          SelectionMode="None"
                                          IsItemClickEnabled="False"
                                          HorizontalContentAlignment="Stretch">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="pages:UserItemViewModel">
                                            <Grid Padding="8,10" BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}" BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3.8*" />
                                                <ColumnDefinition Width="1.6*" />
                                                <ColumnDefinition Width="2.8*" />
                                                <ColumnDefinition Width="1.2*" />
                                            </Grid.ColumnDefinitions>

                                            <Grid Grid.Column="0" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid Width="32" Height="32">
                                                    <Border Width="32"
                                                            Height="32"
                                                            CornerRadius="16"
                                                            Background="{StaticResource FluentPlayPrimaryFixedColor}"
                                                            Visibility="{x:Bind IsAdmin, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <TextBlock Text="{x:Bind Initials, Mode=OneWay}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource FluentPlayOnPrimaryFixedVariantColor}" FontWeight="Bold" />
                                                    </Border>
                                                    <Border Width="32"
                                                            Height="32"
                                                            CornerRadius="16"
                                                            Background="#FFF2C2"
                                                            Visibility="{x:Bind IsSale, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <TextBlock Text="{x:Bind Initials, Mode=OneWay}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#A97400" FontWeight="Bold" />
                                                    </Border>
                                                </Grid>
                                                <TextBlock Grid.Column="1"
                                                           Text="{x:Bind Username, Mode=OneWay}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource FluentPlayOnSurfaceBrush}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Left"
                                                           TextAlignment="Left"
                                                           Margin="10,0,0,0" />
                                            </Grid>

                                            <Grid Grid.Column="1">
                                                <Border Background="{StaticResource FluentPlayPrimaryFixedColor}"
                                                        CornerRadius="999"
                                                        Padding="10,4"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        Margin="0,4,0,0"
                                                        Visibility="{x:Bind IsAdmin, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock Text="{x:Bind RoleLabel, Mode=OneWay}" Foreground="{StaticResource FluentPlayPrimaryBrush}" FontSize="10" FontWeight="Bold" CharacterSpacing="90" />
                                                </Border>
                                                <Border Background="#FFF2C2"
                                                        CornerRadius="999"
                                                        Padding="10,4"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        Margin="0,4,0,0"
                                                        Visibility="{x:Bind IsSale, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock Text="{x:Bind RoleLabel, Mode=OneWay}" Foreground="#A97400" FontSize="10" FontWeight="Bold" CharacterSpacing="90" />
                                                </Border>
                                            </Grid>

                                            <Grid Grid.Column="2" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <ScrollViewer Grid.Column="0"
                                                              HorizontalScrollMode="Enabled"
                                                              HorizontalScrollBarVisibility="Auto"
                                                              VerticalScrollMode="Disabled"
                                                              VerticalScrollBarVisibility="Hidden"
                                                              ZoomMode="Disabled"
                                                              Margin="0,0,8,0">
                                                    <TextBlock Text="{x:Bind PasswordDisplay, Mode=OneWay}"
                                                               FontSize="14"
                                                               Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"
                                                               TextWrapping="NoWrap" />
                                                </ScrollViewer>
                                                <Button Command="{Binding ViewModel.TogglePasswordCommand, ElementName=RootPage}"
                                                        Grid.Column="1"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Padding="0"
                                                        ToolTipService.ToolTip="Show/Hide password">
                                                    <SymbolIcon Symbol="View" />
                                                </Button>
                                            </Grid>

                                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                                <Button Background="Transparent"
                                                        BorderThickness="0"
                                                        Padding="0"
                                                        Foreground="{StaticResource FluentPlayPrimaryBrush}"
                                                        Click="UpdateUserButton_Click"
                                                        CommandParameter="{Binding}">
                                                    <SymbolIcon Symbol="Edit" />
                                                </Button>
                                                <Button Background="Transparent"
                                                        BorderThickness="0"
                                                        Padding="0"
                                                        Foreground="{StaticResource FluentPlayPrimaryBrush}"
                                                        Click="DeleteUserButton_Click"
                                                        CommandParameter="{Binding}">
                                                    <SymbolIcon Symbol="Delete" />
                                                </Button>
                                            </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
                </Border>

                <controls:PaginationControl
                    Grid.Row="3"
                    Margin="0,8,0,0"
                    FirstPageCommand="{x:Bind ViewModel.FirstPageCommand, Mode=OneWay}"
                    LastPageCommand="{x:Bind ViewModel.LastPageCommand, Mode=OneWay}"
                    NextPageCommand="{x:Bind ViewModel.NextPageCommand, Mode=OneWay}"
                    PreviousPageCommand="{x:Bind ViewModel.PreviousPageCommand, Mode=OneWay}"
                    TotalItems="{x:Bind ViewModel.TotalCount, Mode=OneWay}" />

                <controls:AppFooter Grid.Row="4" Margin="0,8,0,0" />
            </Grid>
        </ScrollViewer>

        <ContentDialog x:Name="CreateUserDialog"
                       Title="Create User"
                       PrimaryButtonText="Create"
                       CloseButtonText="Cancel"
                       PrimaryButtonClick="CreateUserDialog_PrimaryButtonClick"
                       DefaultButton="Primary">
            <StackPanel Spacing="12">
                <TextBox x:Name="CreateUsernameTextBox"
                         Header="Username"
                         PlaceholderText="Enter username" />
                <PasswordBox x:Name="CreatePasswordBox"
                             Header="Password"
                             PlaceholderText="Enter password" />
                <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                           TextWrapping="WrapWholeWords">
                    <TextBlock.Foreground>
                        <SolidColorBrush Color="{StaticResource FluentPlayErrorColor}" />
                    </TextBlock.Foreground>
                </TextBlock>
            </StackPanel>
        </ContentDialog>

        <ContentDialog x:Name="UpdateUserDialog"
                       Title="Update User"
                       PrimaryButtonText="Update"
                       CloseButtonText="Cancel"
                       PrimaryButtonClick="UpdateUserDialog_PrimaryButtonClick"
                       DefaultButton="Primary">
            <StackPanel Spacing="12">
                <TextBox x:Name="UpdateUsernameTextBox"
                         Header="Username"
                         PlaceholderText="Enter username" />
                <PasswordBox x:Name="UpdatePasswordBox"
                             Header="Password"
                             PlaceholderText="Enter password" />
                <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                           TextWrapping="WrapWholeWords">
                    <TextBlock.Foreground>
                        <SolidColorBrush Color="{StaticResource FluentPlayErrorColor}" />
                    </TextBlock.Foreground>
                </TextBlock>
            </StackPanel>
        </ContentDialog>
    </Grid>
</Page>
