<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BIF.ToyStore.WinUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:BIF.ToyStore.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    RequestedTheme="Light"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="TaxCardIconBackgroundBrush"
                         Color="#FFF4DEA9"/>
        <SolidColorBrush x:Key="ReceiptCardIconBackgroundBrush"
                         Color="#FFFCE7D2"/>
        <SolidColorBrush x:Key="GeneralCardIconBackgroundBrush"
                         Color="#FFF7D8C4"/>
        <SolidColorBrush x:Key="BackupCardIconBackgroundBrush"
                         Color="#FFE5E7EB"/>
    </Page.Resources>

    <Grid x:Name="SettingsRoot"
          Background="{StaticResource FluentPlaySurfaceBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      HorizontalScrollMode="Disabled">
            <Grid Padding="32"
                  RowSpacing="24"
                  HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Spacing="4">
                    <TextBlock Text="Settings"
                               FontSize="30"
                               FontWeight="ExtraBold"
                               Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                    <TextBlock Text="Configure store environment and system parameters."
                               FontSize="16"
                               Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Background="White"
                        CornerRadius="12"
                        BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                        BorderThickness="1"
                        Padding="24">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Server Configuration"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                            <TextBlock Text="Manage networking and communication ports"
                                       FontSize="14"
                                       Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                        </StackPanel>

                        <Grid ColumnSpacing="172">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <NumberBox x:Name="CommunicationPortNumberBox"
                                       Grid.Column="0"
                                       Header="COMMUNICATION PORT"
                                       Minimum="1"
                                       Maximum="65535"
                                       SmallChange="1"
                                       SpinButtonPlacementMode="Hidden"
                                       Value="{x:Bind ViewModel.CommunicationPort, Mode=TwoWay}"/>

                            <Grid Grid.Column="1"
                                  ColumnSpacing="12"
                                  VerticalAlignment="Bottom">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="0">
                                    <TextBlock Text="Auto-reconnect on Failure"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                                    <TextBlock Text="Attempts to ping server if connection drops"
                                               FontSize="12"
                                               Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1"
                                          IsChecked="{x:Bind ViewModel.AutoReconnect, Mode=TwoWay}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2"
                      ColumnSpacing="24"
                      RowSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="1"
                            Grid.Column="0"
                            Background="White"
                            CornerRadius="12"
                            BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                            BorderThickness="1"
                            Padding="24">
                        <StackPanel Spacing="20">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="40"
                                        Height="40"
                                        CornerRadius="10"
                                        Background="{StaticResource TaxCardIconBackgroundBrush}">
                                    <Image Source="ms-appx:///Assets/Icons/Financial.svg"
                                           Width="20"
                                           Height="20"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1"
                                            Spacing="4"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Tax and Financials"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                                    <TextBlock Text="Define global tax rates and regional currency"
                                               FontSize="14"
                                               Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                </StackPanel>
                            </Grid>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0"
                                      ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <NumberBox Grid.Column="0"
                                               Header="STANDARD TAX RATE"
                                               Minimum="0"
                                               Maximum="100"
                                               SmallChange="0.5"
                                               SpinButtonPlacementMode="Hidden"
                                               Value="{x:Bind ViewModel.TaxRate, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="1"
                                               Text="%"
                                               VerticalAlignment="Bottom"
                                               Margin="0,0,8,8"
                                               Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                </Grid>

                                <StackPanel Grid.Column="1"
                                            Spacing="4"
                                            VerticalAlignment="Bottom">
                                    <TextBlock Text="Currency Symbol"
                                               FontSize="14"
                                               FontWeight="Medium"
                                               CharacterSpacing="1"
                                               Foreground="{StaticResource LoginTextBrush}"/>
                                    <Button Height="32"
                                            Padding="12,0"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Background="{StaticResource LoginCardBrush}"
                                            BorderBrush="{StaticResource LoginDividerBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <TextBlock Text="{x:Bind ViewModel.SelectedCurrency, Mode=OneWay}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource LoginTextBrush}"/>
                                        <Button.Flyout>
                                            <MenuFlyout Placement="Bottom">
                                                <MenuFlyoutItem Text="VND"
                                                                Tag="VND"
                                                                Click="CurrencyOption_Click"/>
                                                <MenuFlyoutItem Text="USD"
                                                                Tag="USD"
                                                                Click="CurrencyOption_Click"/>
                                            </MenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0"
                            Grid.Column="1"
                            Background="White"
                            CornerRadius="12"
                            BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                            BorderThickness="1"
                            Padding="24">
                        <StackPanel Spacing="16">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="40"
                                        Height="40"
                                        CornerRadius="10"
                                        Background="{StaticResource ReceiptCardIconBackgroundBrush}">
                                    <Image Source="ms-appx:///Assets/Icons/Receipt.svg"
                                           Width="20"
                                           Height="20"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1"
                                            Spacing="4"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Receipt Settings"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                                    <TextBlock Text="Customize customer receipt information"
                                               FontSize="14"
                                               Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                </StackPanel>
                            </Grid>

                            <TextBox Header="RECEIPT HEADER"
                                     Text="{x:Bind ViewModel.ReceiptHeader, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBox Header="RECEIPT FOOTER"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="84"
                                     Text="{x:Bind ViewModel.ReceiptFooter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0"
                            Grid.Column="0"
                            Background="White"
                            CornerRadius="12"
                            BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                            BorderThickness="1"
                            Padding="24">
                        <StackPanel Spacing="16">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="40"
                                        Height="40"
                                        CornerRadius="10"
                                        Background="{StaticResource GeneralCardIconBackgroundBrush}">
                                    <Image Source="ms-appx:///Assets/Icons/General.svg"
                                           Width="20"
                                           Height="20"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1"
                                            Spacing="4"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="General Settings"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                                    <TextBlock Text="Interface behavior and list preferences"
                                               FontSize="14"
                                               Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                </StackPanel>
                            </Grid>

                            <Grid ColumnSpacing="24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Store Name"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                                    <TextBlock Text="Displayed in the app sidebar and receipts"
                                               FontSize="12"
                                               Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                </StackPanel>
                                <TextBox Grid.Column="1"
                                         HorizontalAlignment="Stretch"
                                         Margin="0,4,0,0"
                                         MaxLength="18"
                                         Text="{x:Bind ViewModel.StoreName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <Grid ColumnSpacing="24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Items Per Page"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                                    <TextBlock Text="Number of products shown in grid view"
                                               FontSize="12"
                                               Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Width="120"
                                        Height="32"
                                        Margin="0,4,0,0"
                                        Padding="12,0"
                                        HorizontalContentAlignment="Stretch"
                                        Background="{StaticResource LoginCardBrush}"
                                        BorderBrush="{StaticResource LoginDividerBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <TextBlock Text="{x:Bind ViewModel.SelectedItemsPerPage, Mode=OneWay}"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource LoginTextBrush}"/>
                                    <Button.Flyout>
                                        <MenuFlyout Placement="Bottom">
                                            <MenuFlyoutItem Text="5"
                                                            Tag="5"
                                                            Click="ItemsPerPageOption_Click"/>
                                            <MenuFlyoutItem Text="10"
                                                            Tag="10"
                                                            Click="ItemsPerPageOption_Click"/>
                                            <MenuFlyoutItem Text="15"
                                                            Tag="15"
                                                            Click="ItemsPerPageOption_Click"/>
                                            <MenuFlyoutItem Text="20"
                                                            Tag="20"
                                                            Click="ItemsPerPageOption_Click"/>
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                            </Grid>

                            <Grid ColumnSpacing="24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Start on last opened feature"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                                    <TextBlock Text="Open the most recently viewed section after login"
                                               FontSize="12"
                                               Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1"
                                          Margin="0,4,0,0"
                                          IsChecked="{x:Bind ViewModel.StartOnLastOpened, Mode=TwoWay}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Background="White"
                            CornerRadius="12"
                            BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                            BorderThickness="1"
                            Padding="24">
                        <StackPanel Spacing="16">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="40"
                                        Height="40"
                                        CornerRadius="10"
                                        Background="{StaticResource BackupCardIconBackgroundBrush}">
                                    <Image Source="ms-appx:///Assets/Icons/Backup.svg"
                                           Width="20"
                                           Height="20"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1"
                                            Spacing="4"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Backup and Restore"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                                    <TextBlock Text="Safeguard your data and inventory records"
                                               FontSize="14"
                                               Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                </StackPanel>
                            </Grid>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Background="#FFF2F2F2"
                                        BorderBrush="#FFF2F2F2"
                                        CornerRadius="8"
                                        Padding="12,8"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        MinHeight="54"
                                        Command="{x:Bind ViewModel.CreateBackupCommand}">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="20"
                                                VerticalAlignment="Center">
                                        <Image Source="ms-appx:///Assets/Icons/Upload.svg"
                                               Width="24"
                                               Height="24"/>
                                        <StackPanel Spacing="0">
                                            <TextBlock Text="Create Backup"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                                            <TextBlock Text="{x:Bind ViewModel.LastBackupStatus, Mode=OneWay}"
                                                       FontSize="12"
                                                       CharacterSpacing="80"
                                                       Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Button>

                                <Button Grid.Column="1"
                                        Background="#FFF2F2F2"
                                        BorderBrush="#FFF2F2F2"
                                        CornerRadius="8"
                                        Padding="12,8"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        MinHeight="84"
                                        Click="RestoreSystemButton_Click">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="20"
                                                VerticalAlignment="Center">
                                        <Image Source="ms-appx:///Assets/Icons/Restore.svg"
                                               Width="20"
                                               Height="20"/>
                                        <StackPanel Spacing="0">
                                            <TextBlock Text="Restore System"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource FluentPlayOnSurfaceBrush}"/>
                                            <TextBlock Text="REQUIRES ADMIN AUTH"
                                                       FontSize="12"
                                                       CharacterSpacing="80"
                                                       Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock Grid.Row="3"
                           Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                           TextWrapping="Wrap"/>

                <TextBlock Grid.Row="4"
                           Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                           TextWrapping="Wrap"/>

                <StackPanel Grid.Row="5"
                            Spacing="16"
                            Margin="0,4,0,0">
                    <Grid ColumnSpacing="12"
                          Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="1"
                                MinWidth="130"
                                Content="Discard Changes"
                                Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"
                                Command="{x:Bind ViewModel.DiscardChangesCommand}"/>

                        <Button Grid.Column="2"
                                MinWidth="132"
                                Content="Save Changes"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Click="SaveChangesButton_Click">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver"
                                                 Color="{StaticResource FluentPlayPrimaryHoverColor}"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed"
                                                 Color="{StaticResource FluentPlayPrimaryPressedColor}"/>
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver"
                                                 Color="{StaticResource FluentPlayOnPrimaryColor}"/>
                                <SolidColorBrush x:Key="ButtonForegroundPressed"
                                                 Color="{StaticResource FluentPlayOnPrimaryColor}"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver"
                                                 Color="{StaticResource FluentPlayPrimaryHoverColor}"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPressed"
                                                 Color="{StaticResource FluentPlayPrimaryPressedColor}"/>
                            </Button.Resources>
                        </Button>
                    </Grid>

                </StackPanel>

                <controls:AppFooter Grid.Row="6"
                                    Margin="0,8,0,0"/>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
