<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BIF.ToyStore.WinUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:BIF.ToyStore.WinUI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    RequestedTheme="Light"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="TaxCardIconBackgroundBrush" Color="#FFF4DEA9" />
        <SolidColorBrush x:Key="ReceiptCardIconBackgroundBrush" Color="#FFFCE7D2" />
        <SolidColorBrush x:Key="GeneralCardIconBackgroundBrush" Color="#FFF7D8C4" />
        <SolidColorBrush x:Key="BackupCardIconBackgroundBrush" Color="#FFE5E7EB" />
    </Page.Resources>

    <Grid Background="{StaticResource FluentPlaySurfaceBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      HorizontalScrollMode="Disabled">
            <Grid Padding="32" RowSpacing="24" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="4">
                <TextBlock Text="Settings"
                           FontSize="30"
                           FontWeight="ExtraBold"
                           Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                <TextBlock Text="Configure store environment and system parameters."
                           FontSize="16"
                           Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
            </StackPanel>

            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="12"
                    BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                    BorderThickness="1"
                    Padding="24">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Server Configuration"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                        <TextBlock Text="Manage networking and communication ports"
                                   FontSize="14"
                                   Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                    </StackPanel>

                    <Grid ColumnSpacing="60">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="500" />
                            <ColumnDefinition Width="500" />
                        </Grid.ColumnDefinitions>

                        <NumberBox Grid.Column="0"
                                   Header="COMMUNICATION PORT"
                                   Minimum="1"
                                   Maximum="65535"
                                   SmallChange="1"
                                   SpinButtonPlacementMode="Hidden"
                                   Value="{x:Bind ViewModel.CommunicationPort, Mode=TwoWay}" />

                        <Grid Grid.Column="1" ColumnSpacing="12" VerticalAlignment="Bottom">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="0">
                                <TextBlock Text="Auto-reconnect on Failure"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                                <TextBlock Text="Attempts to ping server if connection drops"
                                           FontSize="12"
                                           Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                            </StackPanel>
                            <CheckBox Grid.Column="1"
                                      IsChecked="{x:Bind ViewModel.AutoReconnect, Mode=TwoWay}"
                                      VerticalAlignment="Center" />
                        </Grid>
                    </Grid>
                </StackPanel>
            </Border>

            <Grid Grid.Row="2" ColumnSpacing="24" RowSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Grid.Column="0"
                        Background="White"
                        CornerRadius="12"
                        BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                        BorderThickness="1"
                        Padding="24">
                    <StackPanel Spacing="16">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Width="40"
                                    Height="40"
                                    CornerRadius="10"
                                    Background="{StaticResource TaxCardIconBackgroundBrush}">
                                <Image Source="ms-appx:///Assets/Icons/Financial.svg"
                                       Width="20"
                                       Height="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="Tax and Financials"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                                <TextBlock Text="Define global tax rates and regional currency"
                                           FontSize="14"
                                           Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <NumberBox Grid.Column="0"
                                       Header="STANDARD TAX RATE"
                                       Minimum="0"
                                       Maximum="100"
                                       SmallChange="0.5"
                                       SpinButtonPlacementMode="Hidden"
                                       Value="{x:Bind ViewModel.TaxRate, Mode=TwoWay}" />
                            <TextBlock Grid.Column="1"
                                       Text="%"
                                       VerticalAlignment="Bottom"
                                       Margin="0,0,8,8"
                                       Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                        </Grid>

                        <ComboBox Header="CURRENCY SYMBOL"
                                  Width="180"
                                  ItemsSource="{x:Bind ViewModel.CurrencyOptions, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedCurrency, Mode=TwoWay}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="0"
                        Grid.Column="1"
                        Background="White"
                        CornerRadius="12"
                        BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                        BorderThickness="1"
                        Padding="24">
                    <StackPanel Spacing="16">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Width="40"
                                    Height="40"
                                    CornerRadius="10"
                                    Background="{StaticResource ReceiptCardIconBackgroundBrush}">
                                <Image Source="ms-appx:///Assets/Icons/Receipt.svg"
                                       Width="20"
                                       Height="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="Receipt Settings"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                                <TextBlock Text="Customize customer receipt information"
                                           FontSize="14"
                                           Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                            </StackPanel>
                        </Grid>

                        <TextBox Header="RECEIPT HEADER"
                                 Text="{x:Bind ViewModel.ReceiptHeader, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBox Header="RECEIPT FOOTER"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="84"
                                 Text="{x:Bind ViewModel.ReceiptFooter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Grid.Column="0"
                        Background="White"
                        CornerRadius="12"
                        BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                        BorderThickness="1"
                        Padding="24">
                    <StackPanel Spacing="16">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Width="40"
                                    Height="40"
                                    CornerRadius="10"
                                    Background="{StaticResource GeneralCardIconBackgroundBrush}">
                                <Image Source="ms-appx:///Assets/Icons/General.svg"
                                       Width="20"
                                       Height="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="General Settings"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                                <TextBlock Text="Interface behavior and list preferences"
                                           FontSize="14"
                                           Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="0">
                                <TextBlock Text="Items Per Page"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                                <TextBlock Text="Number of products shown in grid view"
                                           FontSize="12"
                                           Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      Width="120"
                                      ItemsSource="{x:Bind ViewModel.ItemsPerPageOptions, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedItemsPerPage, Mode=TwoWay}" />
                        </Grid>

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="0">
                                <TextBlock Text="Start on last opened feature"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                                <TextBlock Text="Open the most recently viewed section after login"
                                           FontSize="12"
                                           Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                            </StackPanel>
                            <CheckBox Grid.Column="1"
                                      IsChecked="{x:Bind ViewModel.StartOnLastOpened, Mode=TwoWay}"
                                      VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Grid.Column="1"
                        Background="White"
                        CornerRadius="12"
                        BorderBrush="{StaticResource FluentPlayOutlineVariantBrush}"
                        BorderThickness="1"
                        Padding="24">
                    <StackPanel Spacing="16">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Width="40"
                                    Height="40"
                                    CornerRadius="10"
                                    Background="{StaticResource BackupCardIconBackgroundBrush}">
                                <Image Source="ms-appx:///Assets/Icons/Backup.svg"
                                       Width="20"
                                       Height="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="Backup and Restore"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                                <TextBlock Text="Safeguard your data and inventory records"
                                           FontSize="14"
                                           Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Background="#FFF2F2F2"
                                    BorderBrush="#FFF2F2F2"
                                    CornerRadius="8"
                                    Padding="12,8"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    MinHeight="54"
                                    Command="{x:Bind ViewModel.CreateBackupCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                                    <Image Source="ms-appx:///Assets/Icons/Upload.svg"
                                           Width="24"
                                           Height="24" />
                                    <StackPanel Spacing="0">
                                        <TextBlock Text="Create Backup"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                                        <TextBlock Text="{x:Bind ViewModel.LastBackupStatus, Mode=OneWay}"
                                                   FontSize="12"
                                                   CharacterSpacing="80"
                                                   Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="1"
                                    Background="#FFF2F2F2"
                                    BorderBrush="#FFF2F2F2"
                                    CornerRadius="8"
                                    Padding="12,8"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    MinHeight="84"
                                    Command="{x:Bind ViewModel.RestoreSystemCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                                    <Image Source="ms-appx:///Assets/Icons/Restore.svg"
                                           Width="20"
                                           Height="20" />
                                    <StackPanel Spacing="0">
                                        <TextBlock Text="Restore System"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                                        <TextBlock Text="REQUIRES ADMIN AUTH"
                                                   FontSize="12"
                                                   CharacterSpacing="80"
                                                   Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Grid.Row="3"
                       Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                       TextWrapping="Wrap" />

            <TextBlock Grid.Row="4"
                       Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                       TextWrapping="Wrap" />

            <StackPanel Grid.Row="5" Spacing="16" Margin="0,4,0,0">
                <Grid ColumnSpacing="12" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1"
                            MinWidth="130"
                            Content="Discard Changes"
                            Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"
                            Command="{x:Bind ViewModel.DiscardChangesCommand}" />

                    <Button Grid.Column="2"
                            MinWidth="132"
                            Content="Save Changes"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Click="SaveChangesButton_Click">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource FluentPlayPrimaryHoverColor}" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource FluentPlayPrimaryPressedColor}" />
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource FluentPlayOnPrimaryColor}" />
                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource FluentPlayOnPrimaryColor}" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="{StaticResource FluentPlayPrimaryHoverColor}" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="{StaticResource FluentPlayPrimaryPressedColor}" />
                        </Button.Resources>
                    </Button>
                </Grid>

                <controls:AppFooter />
            </StackPanel>
        </Grid>
        </ScrollViewer>
    </Grid>
</Page>
