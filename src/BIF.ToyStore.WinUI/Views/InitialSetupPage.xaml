<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BIF.ToyStore.WinUI.Views.InitialSetupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    RequestedTheme="Light"
    mc:Ignorable="d">

    <Grid x:Name="InitialSetupRoot"
          Background="{StaticResource LoginSurfaceBrush}">
        <Image Source="ms-appx:///Assets/Branding/StoreInterior.jpg"
               Stretch="UniformToFill"/>
        <Rectangle Fill="{StaticResource LoginOverlayBrush}"/>

        <Grid Padding="12">
            <Grid VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="1020"
                        MaxWidth="1020"
                        CornerRadius="12"
                        Background="{StaticResource LoginGlassBrush}">
                    <Border Padding="24"
                            Background="Transparent"
                            CornerRadius="12">
                        <ScrollViewer MaxHeight="700"
                                      Padding="8,0,20,0"
                                      VerticalScrollBarVisibility="Auto"
                                      VerticalScrollMode="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Spacing="16">
                                <StackPanel Margin="0,0,0,4"
                                            Spacing="10"
                                            HorizontalAlignment="Center">
                                    <Border Width="48"
                                            Height="48"
                                            CornerRadius="12"
                                            Background="{ThemeResource FluentPlayPrimaryBrush}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Top"
                                            Padding="0">
                                        <SymbolIcon Symbol="Setting"
                                                    Foreground="{ThemeResource FluentPlayOnPrimaryBrush}"
                                                    Width="32"
                                                    Height="32"/>
                                    </Border>
                                    <TextBlock Text="TOY STORE CONFIGURATION"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               CharacterSpacing="-20"
                                               Foreground="{StaticResource LoginTextBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>

                                <Grid ColumnSpacing="16"
                                      HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Background="{StaticResource LoginCardBrush}"
                                            BorderBrush="{StaticResource LoginDividerBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="16">
                                        <StackPanel Spacing="12">
                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Width="36"
                                                        Height="36"
                                                        CornerRadius="8"
                                                        Background="{ThemeResource FluentPlayPrimaryBrush}">
                                                    <PathIcon Data="M3 20C2.16667 20 1.45833 19.7083 0.875 19.125C0.291667 18.5417 0 17.8333 0 17V14H3V0L4.5 1.5L6 0L7.5 1.5L9 0L10.5 1.5L12 0L13.5 1.5L15 0L16.5 1.5L18 0V17C18 17.8333 17.7083 18.5417 17.125 19.125C16.5417 19.7083 15.8333 20 15 20H3ZM15 18C15.2833 18 15.5208 17.9042 15.7125 17.7125C15.9042 17.5208 16 17.2833 16 17V3H5V14H14V17C14 17.2833 14.0958 17.5208 14.2875 17.7125C14.4792 17.9042 14.7167 18 15 18ZM6 7V5H12V7H6ZM6 10V8H12V10H6ZM14 7C13.7167 7 13.4792 6.90417 13.2875 6.7125C13.0958 6.52083 13 6.28333 13 6C13 5.71667 13.0958 5.47917 13.2875 5.2875C13.4792 5.09583 13.7167 5 14 5C14.2833 5 14.5208 5.09583 14.7125 5.2875C14.9042 5.47917 15 5.71667 15 6C15 6.28333 14.9042 6.52083 14.7125 6.7125C14.5208 6.90417 14.2833 7 14 7ZM14 10C13.7167 10 13.4792 9.90417 13.2875 9.7125C13.0958 9.52083 13 9.28333 13 9C13 8.71667 13.0958 8.47917 13.2875 8.2875C13.4792 8.09583 13.7167 8 14 8C14.2833 8 14.5208 8.09583 14.7125 8.2875C14.9042 8.47917 15 8.71667 15 9C15 9.28333 14.9042 9.52083 14.7125 9.7125C14.5208 9.90417 14.2833 10 14 10ZM3 18H12V16H2V17C2 17.2833 2.09583 17.5208 2.2875 17.7125C2.47917 17.9042 2.71667 18 3 18ZM2 18C2 18 2 17.9042 2 17.7125C2 17.5208 2 17.2833 2 17V16V18Z"
                                                              Width="20"
                                                              Height="20"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Foreground="{ThemeResource FluentPlayOnPrimaryBrush}"/>
                                                </Border>

                                                <StackPanel Grid.Column="1"
                                                            Spacing="2"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="STORE SETTINGS"
                                                               FontSize="12"
                                                               FontWeight="Bold"
                                                               CharacterSpacing="40"
                                                               Foreground="{StaticResource FluentPlayOnSurfaceBrush}"
                                                               Opacity="1"/>
                                                    <TextBlock Text="Manage store name, tax, currency, and receipts"
                                                               FontSize="11"
                                                               Foreground="{StaticResource FluentPlayOnSurfaceBrush}"
                                                               Opacity="0.72"/>
                                                </StackPanel>
                                            </Grid>

                                            <TextBox Header="Store Name"
                                                     Text="{x:Bind ViewModel.StoreName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3*"/>
                                                    <ColumnDefinition Width="2*"/>
                                                </Grid.ColumnDefinitions>

                                                <NumberBox Grid.Column="0"
                                                           Header="Tax Rate (%)"
                                                           SmallChange="0.5"
                                                           SpinButtonPlacementMode="Inline"
                                                           Minimum="0"
                                                           Maximum="100"
                                                           Value="{x:Bind ViewModel.TaxRate, Mode=TwoWay}"/>

                                                <StackPanel Grid.Column="1"
                                                            Spacing="4"
                                                            VerticalAlignment="Bottom">
                                                    <TextBlock Text="Currency Symbol"
                                                               FontSize="14"
                                                               FontWeight="Medium"
                                                               CharacterSpacing="1"
                                                               Foreground="{StaticResource LoginTextBrush}"/>
                                                    <Button Height="32"
                                                            Padding="12,0"
                                                            HorizontalAlignment="Stretch"
                                                            HorizontalContentAlignment="Stretch"
                                                            Background="{StaticResource LoginCardBrush}"
                                                            BorderBrush="{StaticResource LoginDividerBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="6">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{x:Bind ViewModel.SelectedCurrency, Mode=OneWay}"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{StaticResource LoginTextBrush}"/>
                                                        </StackPanel>
                                                        <Button.Flyout>
                                                            <MenuFlyout Placement="Bottom">
                                                                <MenuFlyoutItem Text="VND"
                                                                                Tag="VND"
                                                                                Click="CurrencyOption_Click"/>
                                                                <MenuFlyoutItem Text="USD"
                                                                                Tag="USD"
                                                                                Click="CurrencyOption_Click"/>
                                                            </MenuFlyout>
                                                        </Button.Flyout>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>

                                            <TextBox Header="Receipt Header"
                                                     Text="{x:Bind ViewModel.ReceiptHeader, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                            <TextBox Header="Receipt Footer"
                                                     Text="{x:Bind ViewModel.ReceiptFooter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                Spacing="16">
                                        <Border Background="{StaticResource LoginCardBrush}"
                                                BorderBrush="{StaticResource LoginDividerBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="16">
                                            <StackPanel Spacing="12">
                                                <Grid ColumnSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Width="36"
                                                            Height="36"
                                                            CornerRadius="8"
                                                            Background="{ThemeResource FluentPlayPrimaryBrush}">
                                                        <PathIcon Data="M4.5 3C4.08333 3 3.72917 3.14583 3.4375 3.4375C3.14583 3.72917 3 4.08333 3 4.5C3 4.91667 3.14583 5.27083 3.4375 5.5625C3.72917 5.85417 4.08333 6 4.5 6C4.91667 6 5.27083 5.85417 5.5625 5.5625C5.85417 5.27083 6 4.91667 6 4.5C6 4.08333 5.85417 3.72917 5.5625 3.4375C5.27083 3.14583 4.91667 3 4.5 3ZM4.5 13C4.08333 13 3.72917 13.1458 3.4375 13.4375C3.14583 13.7292 3 14.0833 3 14.5C3 14.9167 3.14583 15.2708 3.4375 15.5625C3.72917 15.8542 4.08333 16 4.5 16C4.91667 16 5.27083 15.8542 5.5625 15.5625C5.85417 15.2708 6 14.9167 6 14.5C6 14.0833 5.85417 13.7292 5.5625 13.4375C5.27083 13.1458 4.91667 13 4.5 13ZM1 0H17C17.2833 0 17.5208 0.0958333 17.7125 0.2875C17.9042 0.479167 18 0.716667 18 1V8C18 8.28333 17.9042 8.52083 17.7125 8.7125C17.5208 8.90417 17.2833 9 17 9H1C0.716667 9 0.479167 8.90417 0.2875 8.7125C0.0958333 8.52083 0 8.28333 0 8V1C0 0.716667 0.0958333 0.479167 0.2875 0.2875C0.479167 0.0958333 0.716667 0 1 0ZM2 2V7H16V2H2ZM1 10H17C17.2833 10 17.5208 10.0958 17.7125 10.2875C17.9042 10.4792 18 10.7167 18 11V18C18 18.2833 17.9042 18.5208 17.7125 18.7125C17.5208 18.9042 17.2833 19 17 19H1C0.716667 19 0.479167 18.9042 0.2875 18.7125C0.0958333 18.5208 0 18.2833 0 18V11C0 10.7167 0.0958333 10.4792 0.2875 10.2875C0.479167 10.0958 0.716667 10 1 10ZM2 12V17H16V12H2ZM2 2V7V2ZM2 12V17V12Z"
                                                                  Width="20"
                                                                  Height="20"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  Foreground="{ThemeResource FluentPlayOnPrimaryBrush}"/>
                                                    </Border>

                                                    <StackPanel Grid.Column="1"
                                                                Spacing="2"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="LOCAL SERVER SETTINGS"
                                                                   FontSize="12"
                                                                   FontWeight="Bold"
                                                                   CharacterSpacing="40"
                                                                   Foreground="{StaticResource FluentPlayOnSurfaceBrush}"
                                                                   Opacity="1"/>
                                                        <TextBlock Text="Configure local service connectivity"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource FluentPlayOnSurfaceBrush}"
                                                                   Opacity="0.72"/>
                                                    </StackPanel>
                                                </Grid>

                                                <NumberBox Header="Local Server Port"
                                                           SmallChange="1"
                                                           SpinButtonPlacementMode="Inline"
                                                           Minimum="1024"
                                                           Maximum="65535"
                                                           Value="{x:Bind ViewModel.LocalServerPort, Mode=TwoWay}"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Background="{StaticResource LoginCardBrush}"
                                                BorderBrush="{StaticResource LoginDividerBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="16">
                                            <StackPanel Spacing="12">
                                                <Grid ColumnSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Width="36"
                                                            Height="36"
                                                            CornerRadius="8"
                                                            Background="{ThemeResource FluentPlayPrimaryBrush}">
                                                        <PathIcon Data="M8 8C6.9 8 5.95833 7.60833 5.175 6.825C4.39167 6.04167 4 5.1 4 4C4 2.9 4.39167 1.95833 5.175 1.175C5.95833 0.391667 6.9 0 8 0C9.1 0 10.0417 0.391667 10.825 1.175C11.6083 1.95833 12 2.9 12 4C12 5.1 11.6083 6.04167 10.825 6.825C10.0417 7.60833 9.1 8 8 8ZM0 16V13.2C0 12.6333 0.145833 12.1125 0.4375 11.6375C0.729167 11.1625 1.11667 10.8 1.6 10.55C2.63333 10.0333 3.68333 9.64583 4.75 9.3875C5.81667 9.12917 6.9 9 8 9C9.1 9 10.1833 9.12917 11.25 9.3875C12.3167 9.64583 13.3667 10.0333 14.4 10.55C14.8833 10.8 15.2708 11.1625 15.5625 11.6375C15.8542 12.1125 16 12.6333 16 13.2V16H0ZM2 14H14V13.2C14 13.0167 13.9542 12.85 13.8625 12.7C13.7708 12.55 13.65 12.4333 13.5 12.35C12.6 11.9 11.6917 11.5625 10.775 11.3375C9.85833 11.1125 8.93333 11 8 11C7.06667 11 6.14167 11.1125 5.225 11.3375C4.30833 11.5625 3.4 11.9 2.5 12.35C2.35 12.4333 2.22917 12.55 2.1375 12.7C2.04583 12.85 2 13.0167 2 13.2V14ZM8 6C8.55 6 9.02083 5.80417 9.4125 5.4125C9.80417 5.02083 10 4.55 10 4C10 3.45 9.80417 2.97917 9.4125 2.5875C9.02083 2.19583 8.55 2 8 2C7.45 2 6.97917 2.19583 6.5875 2.5875C6.19583 2.97917 6 3.45 6 4C6 4.55 6.19583 5.02083 6.5875 5.4125C6.97917 5.80417 7.45 6 8 6Z"
                                                                  Width="16"
                                                                  Height="16"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  Foreground="{ThemeResource FluentPlayOnPrimaryBrush}"/>
                                                    </Border>

                                                    <StackPanel Grid.Column="1"
                                                                Spacing="2"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="ADMIN ACCOUNT"
                                                                   FontSize="12"
                                                                   FontWeight="Bold"
                                                                   CharacterSpacing="40"
                                                                   Foreground="{StaticResource FluentPlayOnSurfaceBrush}"
                                                                   Opacity="1"/>
                                                        <TextBlock Text="Create secure administrator credentials"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource FluentPlayOnSurfaceBrush}"
                                                                   Opacity="0.72"/>
                                                    </StackPanel>
                                                </Grid>

                                                <TextBox Header="Admin Username"
                                                         PlaceholderText="Admin username"
                                                         Text="{x:Bind ViewModel.AdminUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                                <PasswordBox Header="Admin Password"
                                                             PasswordRevealMode="Peek"
                                                             PasswordChanged="AdminPasswordBox_PasswordChanged"/>

                                                <PasswordBox Header="Confirm Password"
                                                             PasswordRevealMode="Peek"
                                                             PasswordChanged="ConfirmAdminPasswordBox_PasswordChanged"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>

                                <Button Click="OnSaveConfigurationClick"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Height="52"
                                        HorizontalAlignment="Stretch"
                                        MinWidth="0"
                                        CornerRadius="8"
                                        Margin="0,2,0,0">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver"
                                                         Color="{StaticResource FluentPlayPrimaryHoverColor}"/>
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed"
                                                         Color="{StaticResource FluentPlayPrimaryPressedColor}"/>
                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver"
                                                         Color="{StaticResource FluentPlayOnPrimaryColor}"/>
                                        <SolidColorBrush x:Key="ButtonForegroundPressed"
                                                         Color="{StaticResource FluentPlayOnPrimaryColor}"/>
                                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver"
                                                         Color="{StaticResource FluentPlayPrimaryHoverColor}"/>
                                        <SolidColorBrush x:Key="ButtonBorderBrushPressed"
                                                         Color="{StaticResource FluentPlayPrimaryPressedColor}"/>
                                    </Button.Resources>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                Spacing="8">
                                        <TextBlock Text="Complete Setup"
                                                   FontWeight="SemiBold"
                                                   FontSize="16"/>
                                        <Image Source="ms-appx:///Assets/Icons/Enter.svg"
                                               Width="14"
                                               Height="14"/>
                                    </StackPanel>
                                </Button>

                                <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                                           HorizontalAlignment="Center"
                                           Opacity="0.5"
                                           FontSize="10"
                                           FontWeight="Medium"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
