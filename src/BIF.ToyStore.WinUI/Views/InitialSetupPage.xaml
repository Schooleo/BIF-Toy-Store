<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BIF.ToyStore.WinUI.Views.InitialSetupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    RequestedTheme="Light"
    mc:Ignorable="d">

    <Grid Background="{StaticResource LoginSurfaceBrush}">
        <Image Source="ms-appx:///Assets/Branding/StoreInterior.png"
               Stretch="UniformToFill"/>
        <Rectangle Fill="{StaticResource LoginOverlayBrush}"/>

        <Grid Padding="12">
            <Grid VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="560"
                        MaxWidth="560"
                        CornerRadius="12"
                        Background="{StaticResource LoginGlassBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="28"
                                Background="Transparent"
                                CornerRadius="12,12,0,0">
                            <ScrollViewer MaxHeight="620"
                                          Padding="8,0,16,0"
                                          VerticalScrollBarVisibility="Auto"
                                          VerticalScrollMode="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Spacing="14">
                                    <Grid Height="126"
                                          Margin="0,0,0,6">
                                        <Border Width="64"
                                                Height="64"
                                                CornerRadius="12"
                                                Background="#FF0078D4"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Top">
                                            <Image Source="ms-appx:///Assets/Icons/Server.svg"
                                                   Width="30"
                                                   Height="30"/>
                                        </Border>
                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Bottom"
                                                    Spacing="4">
                                            <TextBlock Text="Initial Setup"
                                                       FontSize="24"
                                                       FontWeight="Bold"
                                                       CharacterSpacing="-60"
                                                       Foreground="{StaticResource LoginTextBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="Configure store defaults and create the owner account"
                                                       FontSize="13"
                                                       Foreground="{StaticResource LoginTextBrush}"
                                                       Opacity="0.7"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="STORE SETTINGS"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               CharacterSpacing="120"
                                               Foreground="{StaticResource LoginTextBrush}"
                                               Opacity="0.8"/>

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBox Grid.Column="0"
                                                 Header="Store Name"
                                                 Text="{x:Bind ViewModel.StoreName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                        <NumberBox Grid.Column="1"
                                                   Header="Local Server Port"
                                                   SmallChange="1"
                                                   SpinButtonPlacementMode="Inline"
                                                   Minimum="1024"
                                                   Maximum="65535"
                                                   Value="{x:Bind ViewModel.LocalServerPort, Mode=TwoWay}"/>
                                    </Grid>

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>

                                        <NumberBox Grid.Column="0"
                                                   Header="Tax Rate (%)"
                                                   SmallChange="0.5"
                                                   SpinButtonPlacementMode="Inline"
                                                   Minimum="0"
                                                   Maximum="100"
                                                   Value="{x:Bind ViewModel.TaxRate, Mode=TwoWay}"/>

                                        <StackPanel Grid.Column="1"
                                                    Spacing="4"
                                                    VerticalAlignment="Bottom">
                                            <TextBlock Text="Currency Symbol"
                                                       FontSize="14"
                                                       FontWeight="Medium"
                                                       CharacterSpacing="1"
                                                       Foreground="{StaticResource LoginTextBrush}"/>
                                            <Button Height="32"
                                                    Padding="12,0"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Stretch"
                                                    Background="{StaticResource LoginCardBrush}"
                                                    BorderBrush="{StaticResource LoginDividerBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{x:Bind ViewModel.SelectedCurrency, Mode=OneWay}"
                                                               VerticalAlignment="Center"
                                                               Foreground="{StaticResource LoginTextBrush}"/>
                                                </StackPanel>
                                                <Button.Flyout>
                                                    <MenuFlyout Placement="Bottom">
                                                        <MenuFlyoutItem Text="VND"
                                                                        Tag="VND"
                                                                        Click="CurrencyOption_Click"/>
                                                        <MenuFlyoutItem Text="USD"
                                                                        Tag="USD"
                                                                        Click="CurrencyOption_Click"/>
                                                    </MenuFlyout>
                                                </Button.Flyout>
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <TextBox Header="Receipt Header"
                                             Text="{x:Bind ViewModel.ReceiptHeader, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBox Header="Receipt Footer"
                                             Text="{x:Bind ViewModel.ReceiptFooter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Text="OWNER ADMIN ACCOUNT"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               CharacterSpacing="120"
                                               Foreground="{StaticResource LoginTextBrush}"
                                               Opacity="0.8"
                                               Margin="0,4,0,0"/>

                                    <TextBox Header="Admin Username"
                                             PlaceholderText="Store owner username"
                                             Text="{x:Bind ViewModel.AdminUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <PasswordBox Grid.Column="0"
                                                     Header="Admin Password"
                                                     PasswordRevealMode="Peek"
                                                     PasswordChanged="AdminPasswordBox_PasswordChanged"/>

                                        <PasswordBox Grid.Column="1"
                                                     Header="Confirm Password"
                                                     PasswordRevealMode="Peek"
                                                     PasswordChanged="ConfirmAdminPasswordBox_PasswordChanged"/>
                                    </Grid>

                                    <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0"/>

                                    <Button Click="OnSaveConfigurationClick"
                                            Style="{StaticResource PrimaryActionButtonStyle}"
                                            Height="52"
                                            HorizontalAlignment="Stretch"
                                            MinWidth="0"
                                            CornerRadius="8"
                                            Margin="0,2,0,0">
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver"
                                                             Color="{StaticResource FluentPlayPrimaryHoverColor}"/>
                                            <SolidColorBrush x:Key="ButtonBackgroundPressed"
                                                             Color="{StaticResource FluentPlayPrimaryPressedColor}"/>
                                            <SolidColorBrush x:Key="ButtonForegroundPointerOver"
                                                             Color="{StaticResource FluentPlayOnPrimaryColor}"/>
                                            <SolidColorBrush x:Key="ButtonForegroundPressed"
                                                             Color="{StaticResource FluentPlayOnPrimaryColor}"/>
                                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver"
                                                             Color="{StaticResource FluentPlayPrimaryHoverColor}"/>
                                            <SolidColorBrush x:Key="ButtonBorderBrushPressed"
                                                             Color="{StaticResource FluentPlayPrimaryPressedColor}"/>
                                        </Button.Resources>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    Spacing="8">
                                            <TextBlock Text="Complete Setup"
                                                       FontWeight="SemiBold"
                                                       FontSize="16"/>
                                            <Image Source="ms-appx:///Assets/Icons/Enter.svg"
                                                   Width="14"
                                                   Height="14"/>
                                        </StackPanel>
                                    </Button>

                                    <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                                               HorizontalAlignment="Center"
                                               Opacity="0.5"
                                               FontSize="10"
                                               FontWeight="Medium"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Row="1"
                                Background="{StaticResource LoginCardFooterBrush}"
                                Padding="20,12"
                                CornerRadius="0,0,12,12">
                            <TextBlock Text="The first account is created with Admin role and represents the store owner."
                                       FontSize="11"
                                       Foreground="{StaticResource LoginTextBrush}"
                                       Opacity="0.85"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
