<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BIF.ToyStore.WinUI.Views.ReportsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:BIF.ToyStore.WinUI.Controls"
    xmlns:converters="using:BIF.ToyStore.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="RootPage"
    RequestedTheme="Light"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Color x:Key="SystemAccentColor">#FF005FAA</Color>
        <Color x:Key="SystemAccentColorDark1">#FF004883</Color>
        <Color x:Key="SystemAccentColorDark2">#FF003968</Color>
        <Color x:Key="SystemAccentColorLight1">#FF2A7AC3</Color>
        <Color x:Key="SystemAccentColorLight2">#FF5699D5</Color>
        <Color x:Key="SystemAccentColorLight3">#FF86B8E4</Color>

        <SolidColorBrush x:Key="ReportsCanvasBrush" Color="#FFF3F4F6" />
        <SolidColorBrush x:Key="ReportsCardBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="ReportsBorderBrush" Color="#FFE5E7EB" />
        <SolidColorBrush x:Key="ReportsTitleBrush" Color="#FF111827" />
        <SolidColorBrush x:Key="ReportsSubtitleBrush" Color="#FF6B7280" />
        <SolidColorBrush x:Key="ReportsRevenueBarBrush" Color="#FF1D4ED8" />
        <SolidColorBrush x:Key="ReportsProfitBarBrush" Color="#FF10B981" />

        <Style x:Key="ReportsCalendarDatePickerStyle" TargetType="CalendarDatePicker">
            <Setter Property="Foreground" Value="{ThemeResource CalendarDatePickerTextForeground}" />
            <Setter Property="Background" Value="{ThemeResource CalendarDatePickerBackground}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CalendarDatePickerBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="ReportsSelectorButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource FluentPlayOutlineVariantBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource FluentPlayOnSurfaceBrush}" />
        </Style>

        <Style x:Key="ReportsSelectorListItemStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="MinHeight" Value="32" />
        </Style>

    </Page.Resources>

    <Grid x:Name="LayoutRoot" Background="{StaticResource ReportsCanvasBrush}">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="NarrowLayout" />
                <VisualState x:Name="WideLayout">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="960" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="FilterRow1.Height" Value="0" />
                        <Setter Target="FilterColumn2.Width" Value="*" />
                        <Setter Target="FilterColumn3.Width" Value="Auto" />
                        <Setter Target="FilterColumn4.Width" Value="Auto" />
                        <Setter Target="FilterFromPanel.(Grid.Column)" Value="0" />
                        <Setter Target="FilterToPanel.(Grid.Column)" Value="1" />
                        <Setter Target="FilterGroupPanel.(Grid.Row)" Value="0" />
                        <Setter Target="FilterGroupPanel.(Grid.Column)" Value="2" />
                        <Setter Target="FilterRefreshButton.(Grid.Row)" Value="0" />
                        <Setter Target="FilterRefreshButton.(Grid.Column)" Value="3" />

                        <Setter Target="SalesColumnLeft.Width" Value="250" />
                        <Setter Target="SalesColumnRight.Width" Value="*" />
                        <Setter Target="SalesTrendCard.(Grid.Row)" Value="0" />
                        <Setter Target="SalesTrendCard.(Grid.Column)" Value="1" />

                        <Setter Target="RevenueColumnLeft.Width" Value="250" />
                        <Setter Target="RevenueColumnRight.Width" Value="*" />
                        <Setter Target="RevenueChartCard.(Grid.Row)" Value="0" />
                        <Setter Target="RevenueChartCard.(Grid.Column)" Value="1" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <ScrollViewer
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Auto"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled">
            <Grid Padding="24" RowSpacing="16" HorizontalAlignment="Center" MaxWidth="1260">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="4">
                    <TextBlock Text="Sales &amp; Performance Reports"
                               FontSize="32"
                               FontWeight="ExtraBold"
                               Foreground="{StaticResource ReportsTitleBrush}" />
                    <TextBlock Text="Insights and analytics for your current fiscal period."
                               FontSize="14"
                               Foreground="{StaticResource ReportsSubtitleBrush}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Rectangle Width="4" Height="18" Fill="#FF0EA5E9" RadiusX="2" RadiusY="2" />
                        <TextBlock Text="Report Controls"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ReportsTitleBrush}" />
                    </StackPanel>

                    <Border Background="{StaticResource ReportsCardBrush}"
                            BorderBrush="{StaticResource ReportsBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="16">
                        <Grid x:Name="FiltersGrid" ColumnSpacing="20" RowSpacing="8" HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="FilterColumn1" Width="*" MinWidth="200" />
                            <ColumnDefinition x:Name="FilterColumn2" Width="*" MinWidth="200" />
                            <ColumnDefinition x:Name="FilterColumn3" Width="0" />
                            <ColumnDefinition x:Name="FilterColumn4" Width="0" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition x:Name="FilterRow1" Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel x:Name="FilterFromPanel" Grid.Row="0" Grid.Column="0" Spacing="4" MinWidth="220">
                            <TextBlock Text="FROM DATE"
                                       FontSize="10"
                                       CharacterSpacing="100"
                                       Foreground="{StaticResource ReportsSubtitleBrush}"
                                       FontWeight="SemiBold" />
                            <CalendarDatePicker Date="{Binding FromDate, Mode=TwoWay}"
                                                Style="{StaticResource ReportsCalendarDatePickerStyle}" />
                        </StackPanel>

                        <StackPanel x:Name="FilterToPanel" Grid.Row="0" Grid.Column="1" Spacing="4" MinWidth="220">
                            <TextBlock Text="TO DATE"
                                       FontSize="10"
                                       CharacterSpacing="100"
                                       Foreground="{StaticResource ReportsSubtitleBrush}"
                                       FontWeight="SemiBold" />
                            <CalendarDatePicker Date="{Binding ToDate, Mode=TwoWay}"
                                                Style="{StaticResource ReportsCalendarDatePickerStyle}" />
                        </StackPanel>

                        <StackPanel x:Name="FilterGroupPanel" Grid.Row="1" Grid.Column="0" Spacing="4" MinWidth="180">
                            <TextBlock Text="GROUP"
                                       FontSize="10"
                                       CharacterSpacing="100"
                                       Foreground="{StaticResource ReportsSubtitleBrush}"
                                       FontWeight="SemiBold" />
                            <Button Style="{StaticResource ReportsSelectorButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <PathIcon Width="14" Height="14"
                                              Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"
                                              Data="M0 3H16V5H0V3ZM2 7H14V9H2V7ZM5 11H11V13H5V11Z" />
                                    <TextBlock Text="{Binding SelectedGroupBy.Label, FallbackValue=Day, TargetNullValue=Day}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                                </StackPanel>
                                <Button.Flyout>
                                    <Flyout Placement="BottomEdgeAlignedLeft">
                                        <StackPanel Spacing="4" MinWidth="160">
                                            <TextBlock Text="GROUP BY"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       CharacterSpacing="100"
                                                       Foreground="{StaticResource FluentPlayOnSurfaceVariantBrush}"
                                                       Margin="0,0,0,6" />
                                            <ListView ItemsSource="{x:Bind ViewModel.GroupByOptions, Mode=OneWay}"
                                                      SelectedItem="{Binding SelectedGroupBy, Mode=TwoWay}"
                                                      SelectionMode="Single"
                                                      BorderThickness="0"
                                                      Background="Transparent">
                                                <ListView.ItemContainerStyle>
                                                    <Style TargetType="ListViewItem" BasedOn="{StaticResource ReportsSelectorListItemStyle}" />
                                                </ListView.ItemContainerStyle>
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Label}"
                                                                   FontSize="13"
                                                                   Foreground="{StaticResource FluentPlayOnSurfaceBrush}" />
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </StackPanel>

                        <Button x:Name="FilterRefreshButton" Grid.Row="1" Grid.Column="1"
                                VerticalAlignment="Bottom"
                                MinWidth="140"
                                Height="32"
                                Command="{Binding ApplyFiltersCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource FluentPlayPrimaryPressedColor}" />
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource SystemAccentColorDark2}" />
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource FluentPlayOnPrimaryColor}" />
                                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource FluentPlayOnPrimaryColor}" />
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="{StaticResource FluentPlayPrimaryPressedColor}" />
                                <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="{StaticResource SystemAccentColorDark2}" />
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE72C;" FontSize="12" />
                                <TextBlock Text="Reload" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    </Border>
                </StackPanel>

                <Border Grid.Row="2"
                        Background="#FFFFF7ED"
                        CornerRadius="8"
                        BorderBrush="#FFFCD34D"
                        BorderThickness="1"
                        Padding="10"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#FF9A3412"
                               FontSize="12" />
                </Border>

                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Rectangle Width="4" Height="18" Fill="#FFF59E0B" RadiusX="2" RadiusY="2" />
                    <TextBlock Text="Product Sales Report"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource ReportsTitleBrush}" />
                </StackPanel>

                <Grid Grid.Row="4" x:Name="SalesLayoutGrid" ColumnSpacing="14" RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="SalesColumnLeft" Width="*" />
                        <ColumnDefinition x:Name="SalesColumnRight" Width="0" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0" Grid.Column="0"
                            Background="{StaticResource ReportsCardBrush}"
                            BorderBrush="{StaticResource ReportsBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18"
                            VerticalAlignment="Top">
                        <StackPanel Spacing="10">
                            <TextBlock Text="TOTAL ITEMS SOLD"
                                       FontSize="10"
                                       CharacterSpacing="100"
                                       Foreground="{StaticResource ReportsSubtitleBrush}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding TotalItemsSoldDisplay}"
                                       FontSize="42"
                                       FontWeight="ExtraBold"
                                       Foreground="{StaticResource ReportsTitleBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="↗"
                                           FontSize="12"
                                           Foreground="#FF22C55E"
                                           FontWeight="Bold" />
                                <TextBlock Text="12.6% vs last month"
                                           FontSize="12"
                                           Foreground="#FF16A34A" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border x:Name="SalesTrendCard"
                            Grid.Row="1"
                            Grid.Column="0"
                            Background="{StaticResource ReportsCardBrush}"
                            BorderBrush="{StaticResource ReportsBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="QUANTITY SOLD OVER TIME"
                                           FontSize="11"
                                           CharacterSpacing="100"
                                           Foreground="{StaticResource ReportsSubtitleBrush}"
                                           FontWeight="SemiBold" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource ReportsRevenueBarBrush}" />
                                    <TextBlock Text="Active Toys"
                                               FontSize="11"
                                               Foreground="{StaticResource ReportsSubtitleBrush}" />
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="1"
                                    BorderBrush="#FFE5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Background="#FFF8FAFC"
                                    Height="230"
                                    Padding="8,8,8,4">
                                <Viewbox Stretch="Fill">
                                    <Grid Width="980" Height="220">
                                        <Path Data="{Binding TrendAreaData}"
                                              Fill="#3B93C5FD"
                                              Stretch="Fill" />
                                        <Path Data="{Binding TrendPathData}"
                                              Stroke="{StaticResource ReportsRevenueBarBrush}"
                                              StrokeThickness="3"
                                              StrokeLineJoin="Round"
                                              Stretch="Fill" />
                                    </Grid>
                                </Viewbox>
                            </Border>

                            <ItemsControl Grid.Row="2" ItemsSource="{Binding TimeSeriesPoints}" Margin="4,0,4,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Label}"
                                                   Width="80"
                                                   FontSize="10"
                                                   Foreground="{StaticResource ReportsSubtitleBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Grid.Row="1"
                                       Text="No time-series data for the selected range."
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource ReportsSubtitleBrush}"
                                       FontSize="12"
                                       Visibility="{Binding IsTimeSeriesEmpty, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Rectangle Width="4" Height="18" Fill="#FF2563EB" RadiusX="2" RadiusY="2" />
                    <TextBlock Text="Revenue &amp; Profit Report"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource ReportsTitleBrush}" />
                </StackPanel>

                <Grid Grid.Row="6" x:Name="RevenueLayoutGrid" ColumnSpacing="14" RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="RevenueColumnLeft" Width="*" />
                        <ColumnDefinition x:Name="RevenueColumnRight" Width="0" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="10" VerticalAlignment="Top">
                        <Border Background="{StaticResource ReportsCardBrush}"
                                BorderBrush="{StaticResource ReportsBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="TOTAL REVENUE"
                                           FontSize="10"
                                           CharacterSpacing="100"
                                           Foreground="{StaticResource ReportsSubtitleBrush}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding TotalRevenueDisplay}"
                                           FontSize="34"
                                           FontWeight="ExtraBold"
                                           Foreground="{StaticResource ReportsTitleBrush}" />
                                <TextBlock Text="Gross earnings in period"
                                           FontSize="11"
                                           Foreground="{StaticResource ReportsSubtitleBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource ReportsCardBrush}"
                                BorderBrush="{StaticResource ReportsBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="TOTAL PROFIT"
                                           FontSize="10"
                                           CharacterSpacing="100"
                                           Foreground="{StaticResource ReportsSubtitleBrush}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding TotalProfitDisplay}"
                                           FontSize="34"
                                           FontWeight="ExtraBold"
                                           Foreground="#FF16A34A" />
                                <TextBlock Text="Net profit margin"
                                           FontSize="11"
                                           Foreground="{StaticResource ReportsSubtitleBrush}" />
                            </StackPanel>
                        </Border>

                        <Button Height="42"
                                HorizontalAlignment="Stretch"
                                MinWidth="0"
                                Command="{Binding ApplyFiltersCommand}"
                                Background="#FFFACC15"
                                Foreground="#FF1F2937"
                                BorderBrush="#FFEAB308"
                                BorderThickness="1"
                                FontWeight="SemiBold">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFEAB308" />
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#FFD4A106" />
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#FFD4A106" />
                                <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#FFB98900" />
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#FF1F2937" />
                                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#FF1F2937" />
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <Image Source="ms-appx:///Assets/Icons/Print.svg" Width="14" Height="14" />
                                <TextBlock Text="Print Detail Report" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Border x:Name="RevenueChartCard"
                            Grid.Row="1"
                            Grid.Column="0"
                            Background="{StaticResource ReportsCardBrush}"
                            BorderBrush="{StaticResource ReportsBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18">
                        <Grid RowSpacing="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="REVENUE VS PROFIT BY PERIOD"
                                           FontSize="11"
                                           CharacterSpacing="100"
                                           Foreground="{StaticResource ReportsSubtitleBrush}"
                                           FontWeight="SemiBold" />

                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" Margin="0,0,14,0">
                                    <Rectangle Width="10" Height="10" Fill="{StaticResource ReportsRevenueBarBrush}" RadiusX="2" RadiusY="2" />
                                    <TextBlock Text="Revenue" FontSize="11" Foreground="{StaticResource ReportsSubtitleBrush}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5">
                                    <Rectangle Width="10" Height="10" Fill="{StaticResource ReportsProfitBarBrush}" RadiusX="2" RadiusY="2" />
                                    <TextBlock Text="Profit" FontSize="11" Foreground="{StaticResource ReportsSubtitleBrush}" />
                                </StackPanel>
                            </Grid>

                            <ItemsControl Grid.Row="1"
                                          ItemsSource="{Binding TimeSeriesPoints}"
                                          Visibility="{Binding HasTimeSeriesData, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="74" Margin="0,0,6,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="160" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       Text="{Binding QuantityDisplay}"
                                                       HorizontalAlignment="Center"
                                                       FontSize="10"
                                                       Foreground="{StaticResource ReportsSubtitleBrush}" />

                                            <Grid Grid.Row="1" VerticalAlignment="Bottom" ColumnSpacing="8" Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Rectangle Grid.Column="0"
                                                           Width="24"
                                                           RadiusX="3"
                                                           RadiusY="3"
                                                           VerticalAlignment="Bottom"
                                                           Height="{Binding RevenueBarHeight}"
                                                           Fill="{StaticResource ReportsRevenueBarBrush}">
                                                    <ToolTipService.ToolTip>
                                                        <TextBlock Text="{Binding RevenueDisplay}" />
                                                    </ToolTipService.ToolTip>
                                                </Rectangle>

                                                <Rectangle Grid.Column="1"
                                                           Width="24"
                                                           RadiusX="3"
                                                           RadiusY="3"
                                                           VerticalAlignment="Bottom"
                                                           Height="{Binding ProfitBarHeight}"
                                                           Fill="{StaticResource ReportsProfitBarBrush}">
                                                    <ToolTipService.ToolTip>
                                                        <TextBlock Text="{Binding ProfitDisplay}" />
                                                    </ToolTipService.ToolTip>
                                                </Rectangle>
                                            </Grid>

                                            <TextBlock Grid.Row="2"
                                                       Text="{Binding Label}"
                                                       Margin="0,8,0,0"
                                                       HorizontalAlignment="Center"
                                                       FontSize="10"
                                                       Foreground="{StaticResource ReportsSubtitleBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Grid.Row="1"
                                       Text="No revenue/profit data found in the selected period."
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource ReportsSubtitleBrush}"
                                       FontSize="12"
                                       Visibility="{Binding IsTimeSeriesEmpty, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                    </Border>
                </Grid>

                <controls:AppFooter Grid.Row="7" Margin="0,8,0,0" />
            </Grid>
        </ScrollViewer>

        <Grid Background="#AA000000"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <ProgressRing IsActive="True" Width="48" Height="48" Foreground="White" />
                <TextBlock Text="Loading reports..."
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
